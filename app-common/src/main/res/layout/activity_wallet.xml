<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/r2w_premium_bg">

    <include layout="@layout/toolbar_activity" />

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/wallet_refresh"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/wallet_bottom_nav"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <androidx.core.widget.NestedScrollView
            android:id="@+id/wallet_scroll"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:id="@+id/wallet_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="@dimen/r2w_screen_padding"
                android:paddingTop="22dp"
                android:paddingBottom="28dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/wallet_title"
                        android:textAppearance="?attr/textAppearanceHeadlineMedium"
                        android:textColor="@color/r2w_premium_text"
                        android:textStyle="bold" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/wallet_request_history"
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:background="@drawable/r2w_wallet_header_history_bg"
                        android:contentDescription="@string/wallet_request_history"
                        android:insetBottom="0dp"
                        android:insetLeft="0dp"
                        android:insetRight="0dp"
                        android:insetTop="0dp"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        android:text=""
                        app:backgroundTint="@null"
                        app:cornerRadius="26dp"
                        app:icon="@drawable/ic_wallet_history_clock"
                        app:iconGravity="textStart"
                        app:iconPadding="0dp"
                        app:iconSize="26dp"
                        app:iconTint="@color/r2w_text_primary" />
                </LinearLayout>


                
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="210dp"
                    android:layout_marginTop="18dp"
                    app:cardBackgroundColor="@android:color/transparent"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="8dp"
                    app:strokeWidth="0dp">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/r2w_wallet_balance_modern"
                        android:clipToPadding="false"
                        android:padding="22dp">

                        <ImageView
                            android:layout_width="170dp"
                            android:layout_height="170dp"
                            android:layout_gravity="end|center_vertical"
                            android:alpha="0.75"
                            android:contentDescription="@null"
                            android:src="@drawable/r2w_wallet_big_mark" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <ImageView
                                    android:layout_width="28dp"
                                    android:layout_height="28dp"
                                    android:contentDescription="@null"
                                    android:src="@drawable/ic_wallet"
                                    app:tint="@android:color/white" />

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="14dp"
                                    android:layout_weight="1"
                                    android:text="@string/wallet_current_balance"
                                    android:textAppearance="?attr/textAppearanceTitleMedium"
                                    android:textColor="@android:color/white"
                                    android:textStyle="bold" />
                            </LinearLayout>

                            <TextView
                                android:id="@+id/wallet_balance"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="22dp"
                                android:ellipsize="end"
                                android:maxLines="1"
                                android:textAppearance="?attr/textAppearanceDisplaySmall"
                                android:textColor="@android:color/white"
                                android:textStyle="bold" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/wallet_request_balance"
                                android:layout_width="wrap_content"
                                android:layout_height="48dp"
                                android:layout_marginTop="18dp"
                                android:background="@drawable/r2w_wallet_secondary_button"
                                android:insetBottom="0dp"
                                android:insetLeft="0dp"
                                android:insetRight="0dp"
                                android:insetTop="0dp"
                                android:minHeight="0dp"
                                android:minWidth="0dp"
                                android:paddingHorizontal="18dp"
                                android:text="@string/wallet_request_balance"
                                android:textAllCaps="false"
                                android:textColor="@color/r2w_premium_primary"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                app:backgroundTint="@null"
                                app:cornerRadius="14dp"
                                app:icon="@drawable/request_balance"
                                app:iconGravity="textStart"
                                app:iconPadding="8dp"
                                app:iconSize="22dp"
                                app:iconTint="@color/r2w_premium_primary" />
                        </LinearLayout>
                    </FrameLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/wallet_low_balance_card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:visibility="gone"
                    app:cardBackgroundColor="@color/r2w_premium_danger_bg"
                    app:cardCornerRadius="20dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Low Balance"
                            android:textAppearance="?attr/textAppearanceTitleSmall"
                            android:textColor="@color/r2w_premium_danger"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/wallet_low_balance_text"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Your balance is low. Add funds to continue purchasing eSIM packages."
                            android:textAppearance="?attr/textAppearanceBodyMedium"
                            android:textColor="@color/r2w_premium_danger" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/wallet_quick_stats_card"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:cardBackgroundColor="@android:color/white"
                    app:cardCornerRadius="22dp"
                    app:cardElevation="2dp"
                    app:strokeColor="@color/r2w_premium_border"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Quick Stats"
                            android:textAppearance="?attr/textAppearanceTitleMedium"
                            android:textColor="@color/r2w_premium_text"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/wallet_quick_stats_text"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:lineSpacingExtra="3dp"
                            android:textAppearance="?attr/textAppearanceBodyMedium"
                            android:textColor="@color/r2w_premium_muted" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:id="@+id/wallet_error"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:textColor="@color/r2w_premium_danger"
                    android:visibility="gone" />

                <LinearLayout
                    android:id="@+id/wallet_requests"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="vertical" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="28dp"
                    android:text="Transaction List"
                    android:textAppearance="?attr/textAppearanceTitleMedium"
                    android:textColor="@color/r2w_premium_text"
                    android:textStyle="bold" />

                <LinearLayout
                    android:id="@+id/wallet_transactions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="vertical" />
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/wallet_bottom_nav"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/r2w_premium_surface"
        app:labelVisibilityMode="labeled"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:menu="@menu/activity_dashboard_bottom" />
</androidx.constraintlayout.widget.ConstraintLayout>
