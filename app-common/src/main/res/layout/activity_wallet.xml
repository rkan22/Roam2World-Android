<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/r2w_premium_bg">

    <include layout="@layout/toolbar_activity" />

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/wallet_refresh"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/wallet_bottom_nav"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <androidx.core.widget.NestedScrollView
            android:id="@+id/wallet_scroll"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:id="@+id/wallet_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="@dimen/r2w_screen_padding"
                android:paddingTop="22dp"
                android:paddingBottom="24dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/dashboard_brand"
                    android:textAppearance="?attr/textAppearanceLabelLarge"
                    android:textColor="@color/r2w_premium_primary" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/wallet_title"
                    android:textAppearance="?attr/textAppearanceHeadlineSmall"
                    android:textColor="@color/r2w_premium_text" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="156dp"
                    android:layout_marginTop="20dp"
                    app:cardBackgroundColor="@color/r2w_premium_primary"
                    app:cardCornerRadius="@dimen/r2w_card_radius"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center_vertical"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/wallet_current_balance"
                            android:textAppearance="?attr/textAppearanceLabelLarge"
                            android:textColor="@android:color/white" />

                        <TextView
                            android:id="@+id/wallet_balance"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:ellipsize="end"
                            android:maxLines="2"
                            android:textAppearance="?attr/textAppearanceDisplaySmall"
                            android:textColor="@android:color/white" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/wallet_low_balance_card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:visibility="gone"
                    app:cardBackgroundColor="@color/r2w_premium_danger_bg"
                    app:cardCornerRadius="@dimen/r2w_card_radius"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Low Balance"
                            android:textAppearance="?attr/textAppearanceTitleSmall"
                            android:textColor="@color/r2w_premium_danger" />

                        <TextView
                            android:id="@+id/wallet_low_balance_text"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Your balance is low. Add funds to continue purchasing eSIM packages."
                            android:textAppearance="?attr/textAppearanceBodyMedium"
                            android:textColor="@color/r2w_premium_danger" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>


                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/wallet_quick_stats_card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    app:cardBackgroundColor="@color/r2w_premium_surface"
                    app:cardCornerRadius="@dimen/r2w_card_radius"
                    app:cardElevation="4dp"
                    app:strokeColor="@color/r2w_premium_border"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Quick Stats"
                            android:textAppearance="?attr/textAppearanceTitleSmall"
                            android:textColor="@color/r2w_premium_text" />

                        <TextView
                            android:id="@+id/wallet_quick_stats_text"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:textAppearance="?attr/textAppearanceBodyMedium"
                            android:textColor="@color/r2w_premium_muted" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>


                <com.google.android.material.button.MaterialButton
                    android:id="@+id/wallet_request_balance"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/r2w_premium_primary_button"
                    android:text="@string/wallet_request_balance"
                    android:textColor="@android:color/white"
                    android:textStyle="bold"
                    app:backgroundTint="@null"
                    app:cornerRadius="@dimen/r2w_button_radius"
                    app:icon="@drawable/ic_add" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/wallet_request_history"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="10dp"
                    android:text="@string/wallet_request_history"
                    app:cornerRadius="@dimen/r2w_button_radius"
                    app:icon="@drawable/ic_checkmark_outline"
                    app:strokeColor="@color/r2w_premium_primary"
                    app:strokeWidth="1dp"
                    android:textColor="@color/r2w_premium_primary" />

                <TextView
                    android:id="@+id/wallet_error"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:textColor="@color/r2w_premium_danger"
                    android:visibility="gone" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="28dp"
                    android:text="@string/wallet_recent_requests"
                    android:textAppearance="?attr/textAppearanceTitleMedium"
                    android:textColor="@color/r2w_premium_text" />

                <LinearLayout
                    android:id="@+id/wallet_requests"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="vertical" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="28dp"
                    android:text="@string/wallet_recent_transactions"
                    android:textAppearance="?attr/textAppearanceTitleMedium"
                    android:textColor="@color/r2w_premium_text" />

                <LinearLayout
                    android:id="@+id/wallet_transactions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="vertical" />
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/wallet_bottom_nav"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/r2w_premium_surface"
        app:labelVisibilityMode="labeled"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:menu="@menu/activity_dashboard_bottom" />
</androidx.constraintlayout.widget.ConstraintLayout>
