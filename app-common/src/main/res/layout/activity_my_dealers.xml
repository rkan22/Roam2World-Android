<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/r2w_premium_bg">

    <include layout="@layout/toolbar_activity" />

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/my_dealers_refresh"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <androidx.core.widget.NestedScrollView
            android:id="@+id/my_dealers_scroll"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:id="@+id/my_dealers_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="@dimen/r2w_screen_padding"
                android:paddingTop="22dp"
                android:paddingBottom="24dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/dashboard_brand"
                    android:textAppearance="?attr/textAppearanceLabelLarge"
                    android:textColor="@color/r2w_premium_primary" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/dealers_title"
                    android:textAppearance="?attr/textAppearanceDisplaySmall"
                    android:textColor="@color/r2w_premium_text" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="104dp"
                    android:layout_marginTop="18dp"
                    app:cardBackgroundColor="@color/r2w_premium_primary_soft"
                    app:cardCornerRadius="@dimen/r2w_card_radius"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center_vertical"
                        android:orientation="vertical"
                        android:padding="@dimen/r2w_card_padding">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/dashboard_dealer_summary"
                            android:textAppearance="?attr/textAppearanceLabelLarge"
                            android:textColor="@color/r2w_premium_primary_dark" />

                        <TextView
                            android:id="@+id/my_dealers_summary"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:textAppearance="?attr/textAppearanceHeadlineSmall"
                            android:textColor="@color/r2w_premium_primary_dark" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>


                <com.google.android.material.button.MaterialButton
                    android:id="@+id/my_dealers_add"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/r2w_premium_primary_button"
                    android:text="@string/dealer_add"
                    android:textColor="@android:color/white"
                    android:textStyle="bold"
                    app:backgroundTint="@null"
                    app:cornerRadius="@dimen/r2w_button_radius" />

                <TextView
                    android:id="@+id/my_dealers_error"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:textColor="@color/r2w_premium_danger"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/my_dealers_empty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/r2w_premium_card_soft"
                    android:padding="@dimen/r2w_card_padding"
                    android:text="@string/dealers_empty"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:textColor="@color/r2w_premium_muted"
                    android:visibility="gone" />

                <LinearLayout
                    android:id="@+id/my_dealers_items"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="vertical" />
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
