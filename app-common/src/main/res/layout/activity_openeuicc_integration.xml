<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/r2w_clean_global_bg">

    <include
        android:id="@+id/toolbar"
        layout="@layout/toolbar_activity" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/openeuicc_scroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingStart="16dp"
        android:paddingTop="10dp"
        android:paddingEnd="16dp"
        android:paddingBottom="28dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/r2w_clean_surface"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/r2w_clean_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="14dp"
                    android:paddingTop="12dp"
                    android:paddingEnd="14dp"
                    android:paddingBottom="12dp">

                    <FrameLayout
                        android:layout_width="46dp"
                        android:layout_height="46dp"
                        android:layout_marginEnd="12dp"
                        android:background="@drawable/r2w_clean_icon_circle">

                        <ImageView
                            android:layout_width="26dp"
                            android:layout_height="26dp"
                            android:layout_gravity="center"
                            android:contentDescription="@null"
                            android:src="@drawable/r2w_ic_globe_clean" />

                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:minWidth="0dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:text="Roam2World"
                            android:textColor="@color/r2w_clean_text"
                            android:textSize="23sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:text="Global eSIM control center"
                            android:textColor="@color/r2w_clean_muted"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/openeuicc_native_status"
                            android:layout_width="wrap_content"
                            android:layout_height="28dp"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/r2w_clean_connected_chip"
                            android:ellipsize="end"
                            android:gravity="center"
                            android:maxLines="1"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:text="Ready • OpenEUICC"
                            android:textColor="@color/r2w_clean_success"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/openeuicc_open_r2w_home"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="10dp"
                        android:text="Roam2World Home"
                        android:textAllCaps="false"
                        android:textColor="@color/r2w_clean_primary"
                        app:cornerRadius="16dp"
                        app:strokeColor="@color/r2w_clean_border" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                app:cardBackgroundColor="@color/r2w_clean_surface"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/r2w_clean_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Connection Status"
                        android:textColor="@color/r2w_clean_text"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="82dp"
                            android:layout_marginEnd="7dp"
                            android:layout_weight="1"
                            android:background="@drawable/r2w_clean_soft_card"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:padding="12dp">

                            <FrameLayout
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:layout_marginEnd="10dp"
                                android:background="@drawable/r2w_clean_icon_circle">

                                <ImageView
                                    android:layout_width="25dp"
                                    android:layout_height="25dp"
                                    android:layout_gravity="center"
                                    android:contentDescription="@null"
                                    android:src="@drawable/ou_ic_usb_modern" />

                            </FrameLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:minWidth="0dp"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:ellipsize="end"
                                    android:maxLines="1"
                                    android:text="USB Reader"
                                    android:textColor="@color/r2w_clean_muted"
                                    android:textSize="12sp" />

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:ellipsize="end"
                                    android:maxLines="1"
                                    android:text="Ready"
                                    android:textColor="@color/r2w_clean_text"
                                    android:textSize="16sp"
                                    android:textStyle="bold" />

                            </LinearLayout>

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="82dp"
                            android:layout_marginStart="7dp"
                            android:layout_weight="1"
                            android:background="@drawable/r2w_clean_soft_card"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:padding="12dp">

                            <FrameLayout
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:layout_marginEnd="10dp"
                                android:background="@drawable/r2w_clean_connected_chip">

                                <ImageView
                                    android:layout_width="25dp"
                                    android:layout_height="25dp"
                                    android:layout_gravity="center"
                                    android:contentDescription="@null"
                                    android:src="@drawable/r2w_ic_shield_clean" />

                            </FrameLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:minWidth="0dp"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:ellipsize="end"
                                    android:maxLines="1"
                                    android:text="eUICC Slot"
                                    android:textColor="@color/r2w_clean_muted"
                                    android:textSize="12sp" />

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:ellipsize="end"
                                    android:maxLines="1"
                                    android:text="Active"
                                    android:textColor="@color/r2w_clean_success"
                                    android:textSize="16sp"
                                    android:textStyle="bold" />

                            </LinearLayout>

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                app:cardBackgroundColor="@color/r2w_clean_surface"
                app:cardCornerRadius="22dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/r2w_clean_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <FrameLayout
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:layout_marginEnd="12dp"
                            android:background="@drawable/r2w_clean_orange_circle">

                            <ImageView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:layout_gravity="center"
                                android:contentDescription="@null"
                                android:src="@drawable/r2w_ic_qr_clean" />

                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:minWidth="0dp"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:ellipsize="end"
                                android:maxLines="1"
                                android:text="Install New eSIM"
                                android:textColor="@color/r2w_clean_text"
                                android:textSize="19sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:ellipsize="end"
                                android:maxLines="2"
                                android:text="QR, activation code, or manual install"
                                android:textColor="@color/r2w_clean_muted"
                                android:textSize="14sp" />

                        </LinearLayout>

                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/openeuicc_install_new"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:layout_marginTop="14dp"
                        android:background="@drawable/r2w_clean_primary_button"
                        android:text="Install"
                        android:textAllCaps="false"
                        android:textColor="@android:color/white"
                        android:textStyle="bold"
                        app:backgroundTint="@null"
                        app:cornerRadius="18dp"
                        app:icon="@drawable/r2w_ic_download_clean"
                        app:iconGravity="textStart"
                        app:iconTint="@android:color/white" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Installed Profiles"
                    android:textColor="@color/r2w_clean_text"
                    android:textSize="19sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:background="@drawable/r2w_clean_orange_chip"
                    android:gravity="center"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:text="B2B"
                    android:textColor="@color/r2w_clean_orange"
                    android:textSize="12sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/openeuicc_profiles"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="vertical" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="8dp"
                app:cardBackgroundColor="@color/r2w_clean_surface"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/r2w_clean_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Utilities"
                        android:textColor="@color/r2w_clean_text"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/openeuicc_refresh_profiles"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="50dp"
                            android:layout_marginEnd="6dp"
                            android:layout_weight="1"
                            android:text="Refresh"
                            android:textAllCaps="false"
                            android:textColor="@color/r2w_clean_primary"
                            app:cornerRadius="16dp"
                            app:icon="@drawable/r2w_ic_refresh_clean"
                            app:iconGravity="textStart"
                            app:iconTint="@color/r2w_clean_primary"
                            app:strokeColor="@color/r2w_clean_border" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/openeuicc_open_native"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="50dp"
                            android:layout_marginStart="6dp"
                            android:layout_weight="1"
                            android:text="Advanced"
                            android:textAllCaps="false"
                            android:textColor="@color/r2w_clean_muted"
                            app:cornerRadius="16dp"
                            app:strokeColor="@color/r2w_clean_border" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
