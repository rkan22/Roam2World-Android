<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/r2w_premium_bg">

    <include layout="@layout/toolbar_activity" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/purchase_review_scroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/r2w_screen_padding">

            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/purchase_review_progress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:indeterminate="true"
                android:visibility="gone" />

            <TextView
                android:id="@+id/purchase_review_error"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="@color/r2w_premium_danger"
                android:visibility="gone" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="@color/r2w_premium_surface"
                app:cardCornerRadius="@dimen/r2w_card_radius"
                app:cardElevation="5dp"
                app:strokeColor="@color/r2w_premium_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/r2w_card_padding">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Order Summary"
                        android:textAppearance="?attr/textAppearanceHeadlineSmall"
                        android:textColor="@color/r2w_premium_text"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/review_customer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:textAppearance="?attr/textAppearanceBodyLarge"
                        android:textColor="@color/r2w_premium_text" />

                    <TextView
                        android:id="@+id/review_phone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:textAppearance="?attr/textAppearanceBodyLarge"
                        android:textColor="@color/r2w_premium_text" />

                    <TextView
                        android:id="@+id/review_package"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:textAppearance="?attr/textAppearanceBodyLarge"
                        android:textColor="@color/r2w_premium_text" />

                    <TextView
                        android:id="@+id/review_provider"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:textAppearance="?attr/textAppearanceBodyLarge"
                        android:textColor="@color/r2w_premium_text" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="18dp"
                        android:background="@color/r2w_premium_border" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:text="Price Breakdown"
                        android:textAppearance="?attr/textAppearanceTitleLarge"
                        android:textColor="@color/r2w_premium_text"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/review_package_price"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:textAppearance="?attr/textAppearanceBodyLarge"
                        android:textColor="@color/r2w_premium_text" />

                    <TextView
                        android:id="@+id/review_tax"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:textAppearance="?attr/textAppearanceBodyLarge"
                        android:textColor="@color/r2w_premium_text" />

                    <TextView
                        android:id="@+id/review_total"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:background="@drawable/r2w_premium_card_soft"
                        android:padding="14dp"
                        android:textAppearance="?attr/textAppearanceHeadlineSmall"
                        android:textColor="@color/r2w_premium_primary"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="18dp"
                        android:background="@color/r2w_premium_border" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:text="Wallet Balance"
                        android:textAppearance="?attr/textAppearanceTitleLarge"
                        android:textColor="@color/r2w_premium_text"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/review_current_balance"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:textAppearance="?attr/textAppearanceBodyLarge"
                        android:textColor="@color/r2w_premium_text" />

                    <TextView
                        android:id="@+id/review_balance_after"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:textAppearance="?attr/textAppearanceBodyLarge"
                        android:textColor="@color/r2w_premium_text" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/purchase_review_sim_iccid_layout"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:hint="SIM ICCID"
                android:visibility="gone"
                app:boxBackgroundColor="@color/r2w_premium_surface"
                app:boxCornerRadiusBottomEnd="16dp"
                app:boxCornerRadiusBottomStart="16dp"
                app:boxCornerRadiusTopEnd="16dp"
                app:boxCornerRadiusTopStart="16dp"
                app:boxStrokeColor="@color/r2w_premium_border"
                app:helperText="Required for Orange Balkans SIM card packages"
                app:hintTextColor="@color/r2w_premium_muted">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/purchase_review_sim_iccid"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:maxLines="1" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/purchase_review_confirm"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="24dp"
                android:background="@drawable/r2w_premium_primary_button"
                android:text="Confirm Purchase"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                app:backgroundTint="@null"
                app:cornerRadius="@dimen/r2w_button_radius" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/purchase_review_cancel"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/r2w_premium_outline_button"
                android:text="Cancel"
                android:textColor="@color/r2w_premium_danger"
                android:textStyle="bold"
                app:backgroundTint="@null"
                app:cornerRadius="@dimen/r2w_button_radius"
                app:strokeColor="@color/r2w_premium_danger"
                app:strokeWidth="1dp" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
