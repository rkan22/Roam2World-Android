<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="14dp"
    android:layout_marginTop="6dp"
    android:layout_marginBottom="10dp"
    app:cardBackgroundColor="@android:color/transparent"
    app:cardCornerRadius="20dp"
    app:cardElevation="0dp"
    app:strokeColor="@android:color/transparent"
    app:strokeWidth="0dp">

    <LinearLayout
        android:id="@+id/profile_item_root"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/ou_profile_real_card_bg"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="2"
                android:text="eSIM Go"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:textColor="?android:textColorPrimary"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/state"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:background="@drawable/ou_profile_status_chip"
                android:gravity="center"
                android:includeFontPadding="false"
                android:minWidth="86dp"
                android:paddingHorizontal="12dp"
                android:text="@string/profile_state_disabled"
                android:textAppearance="?attr/textAppearanceLabelMedium"
                android:textColor="?android:textColorSecondary"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/profile_menu"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:layout_marginStart="6dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@null"
                android:src="@drawable/r2w_ic_more_vertical_modern"
                app:tint="?android:textColorSecondary" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/profile_provider_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="13dp"
            android:background="@drawable/ou_profile_info_panel"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp"
            android:paddingVertical="11dp">

            <TextView
                android:id="@+id/profile_provider_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/profile_provider"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="?android:textColorSecondary"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/provider"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="Travel"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="?android:textColorPrimary" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/profile_iccid_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="9dp"
            android:background="@drawable/ou_profile_info_panel"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp"
            android:paddingVertical="11dp">

            <TextView
                android:id="@+id/profile_iccid_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/profile_iccid"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="?android:textColorSecondary"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/iccid"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:ellipsize="middle"
                android:maxLines="1"
                android:text="89320420000104425986"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="?android:textColorPrimary" />

            <TextView
                android:id="@+id/profile_sequence_number"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginStart="10dp"
                android:background="@drawable/ou_profile_slot_chip"
                android:gravity="center"
                android:minWidth="44dp"
                android:paddingHorizontal="10dp"
                android:text="#1"
                android:textAppearance="?attr/textAppearanceLabelMedium"
                android:textColor="?android:textColorPrimary"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/profile_class_label"
            android:layout_width="1dp"
            android:layout_height="1dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/profile_class"
            android:layout_width="1dp"
            android:layout_height="1dp"
            android:visibility="gone" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
