<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/r2w_premium_bg">

    <include layout="@layout/toolbar_activity" />

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/purchase_history_refresh"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <androidx.core.widget.NestedScrollView
            android:id="@+id/purchase_history_scroll"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:id="@+id/purchase_history_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="@dimen/r2w_screen_padding"
                android:paddingTop="22dp"
                android:paddingBottom="24dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/dashboard_brand"
                    android:textAppearance="?attr/textAppearanceLabelLarge"
                    android:textColor="@color/r2w_premium_primary" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Orders"
                    android:textAppearance="?attr/textAppearanceHeadlineSmall"
                    android:textColor="@color/r2w_premium_text" />

                <TextView
                    android:id="@+id/purchase_history_summary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Orders and purchase activity"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:textColor="@color/r2w_premium_muted" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/purchase_history_search_layout"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:hint="Search order, package, provider or ICCID"
                    app:boxBackgroundColor="@color/r2w_premium_surface"
                    app:boxCornerRadiusBottomEnd="16dp"
                    app:boxCornerRadiusBottomStart="16dp"
                    app:boxCornerRadiusTopEnd="16dp"
                    app:boxCornerRadiusTopStart="16dp"
                    app:boxStrokeColor="@color/r2w_premium_border"
                    app:endIconMode="clear_text"
                    app:hintTextColor="@color/r2w_premium_muted"
                    app:startIconDrawable="@drawable/ic_wallet">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/purchase_history_search"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:imeOptions="actionSearch"
                        android:inputType="text"
                        android:maxLines="1" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/purchase_history_tabs"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    app:selectionRequired="true"
                    app:singleSelection="true">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/purchase_history_tab_all"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        android:text="All" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/purchase_history_tab_pending"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Processing" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/purchase_history_tab_completed"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Completed" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/purchase_history_tab_failed"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Failed" />
                </com.google.android.material.chip.ChipGroup>

                <TextView
                    android:id="@+id/purchase_history_error"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:textColor="@color/r2w_premium_danger"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/purchase_history_empty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/r2w_premium_card"
                    android:padding="@dimen/r2w_card_padding"
                    android:text="No matching orders found."
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:textColor="@color/r2w_premium_muted"
                    android:visibility="gone" />

                <LinearLayout
                    android:id="@+id/purchase_history_orders"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="vertical" />
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
