<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/r2w_screen_bg">

    <include
        layout="@layout/toolbar_activity"
        android:visibility="gone" />

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/purchase_history_refresh"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/purchase_history_bottom_nav"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.core.widget.NestedScrollView
            android:id="@+id/purchase_history_scroll"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:id="@+id/purchase_history_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="18dp"
                android:paddingTop="34dp"
                android:paddingEnd="18dp"
                android:paddingBottom="92dp">

                <LinearLayout
                    android:id="@+id/purchase_history_top_bar"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/purchase_history_title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Orders"
                        android:textColor="#111827"
                        android:textSize="28sp"
                        android:textStyle="bold" />

                    <ImageView
                        android:id="@+id/purchase_history_search_icon"
                        android:visibility="gone"
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:layout_marginEnd="18dp"
                        android:contentDescription="@null"
                        android:src="@drawable/r2w_ic_search_ref" />

                    <ImageView
                        android:id="@+id/purchase_history_filter_icon"
                        android:visibility="gone"
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:contentDescription="@null"
                        android:src="@drawable/r2w_ic_filter_ref" />
                </LinearLayout>

                <TextView
                    android:id="@+id/purchase_history_subtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="-2dp"
                    android:text="View and manage all customer orders."
                    android:textColor="#667085"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/purchase_history_summary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textColor="#9CA3AF"
                    android:textSize="13sp"
                    android:visibility="gone" />

                <LinearLayout
                    android:id="@+id/purchase_history_tabs"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/r2w_segment_container"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:padding="6dp">

                    <TextView
                        android:id="@+id/purchase_history_tab_all"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginEnd="3dp"
                        android:layout_weight="1"
                        android:background="@drawable/r2w_segment_selected"
                        android:gravity="center"
                        android:maxLines="1"
                        android:text="All"
                        android:textColor="#2563EB"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/purchase_history_tab_completed"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginHorizontal="3dp"
                        android:layout_weight="1"
                        android:background="@drawable/r2w_segment_idle"
                        android:gravity="center"
                        android:maxLines="1"
                        android:text="Completed"
                        android:textColor="#6B7280"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/purchase_history_tab_pending"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginHorizontal="3dp"
                        android:layout_weight="1"
                        android:background="@drawable/r2w_segment_idle"
                        android:gravity="center"
                        android:maxLines="1"
                        android:text="Pending"
                        android:textColor="#6B7280"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/purchase_history_tab_failed"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginStart="3dp"
                        android:layout_weight="1"
                        android:background="@drawable/r2w_segment_idle"
                        android:gravity="center"
                        android:maxLines="1"
                        android:text="Failed"
                        android:textColor="#6B7280"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/purchase_history_search_filter_row"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="16dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:id="@+id/purchase_history_search_layout"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        android:background="@drawable/r2w_filter_button_bg"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="12dp"
                        android:paddingEnd="10dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_order_search"
                            app:tint="#111827" />

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/purchase_history_search"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_marginStart="10dp"
                            android:layout_weight="1"
                            android:background="@android:color/transparent"
                            android:gravity="center_vertical"
                            android:hint="Search by Order ID, Plan..."
                            android:imeOptions="actionSearch"
                            android:includeFontPadding="false"
                            android:inputType="text"
                            android:maxLines="1"
                            android:singleLine="true"
                            android:textColor="#111827"
                            android:textColorHint="#8A94A6"
                            android:textCursorDrawable="@null"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/purchase_history_filter_button"
                        android:layout_width="122dp"
                        android:layout_height="match_parent"
                        android:background="@drawable/r2w_filter_button_bg"
                        android:clickable="true"
                        android:focusable="true"
                        android:drawableStart="@drawable/r2w_ic_filter_ref"
                        android:drawablePadding="8dp"
                        android:gravity="center"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:text="Filters"
                        android:singleLine="true"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:textColor="#0B6BFF"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:id="@+id/purchase_history_error"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:textColor="#EF4444"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/purchase_history_empty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/r2w_order_card_ref"
                    android:padding="18dp"
                    android:text="No matching orders found."
                    android:textColor="#6B7280"
                    android:visibility="gone" />

                <LinearLayout
                    android:id="@+id/purchase_history_orders"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="vertical" />
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/purchase_history_bottom_nav"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/r2w_nav_bar_bg"
        app:itemIconTint="@color/r2w_bottom_nav_colors"
        app:itemRippleColor="@android:color/transparent"
        app:itemTextColor="@color/r2w_bottom_nav_colors"
        app:labelVisibilityMode="labeled"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:menu="@menu/activity_dashboard_bottom" />
</androidx.constraintlayout.widget.ConstraintLayout>
