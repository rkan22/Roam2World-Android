<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/r2w_premium_bg">

    <include layout="@layout/toolbar_activity" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/order_detail_scroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <LinearLayout
            android:id="@+id/order_detail_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/r2w_screen_padding"
            android:paddingTop="22dp"
            android:paddingBottom="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/dashboard_brand"
                android:textAppearance="?attr/textAppearanceLabelLarge"
                android:textColor="@color/r2w_premium_primary" />

            <TextView
                android:id="@+id/order_detail_heading"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textAppearance="?attr/textAppearanceDisplaySmall"
                android:textColor="@color/r2w_premium_text" />

            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/order_detail_progress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:indeterminate="true"
                android:visibility="gone" />

            <TextView
                android:id="@+id/order_detail_error"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="@color/r2w_premium_danger"
                android:visibility="gone" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:cardBackgroundColor="@color/r2w_premium_surface"
                app:cardCornerRadius="@dimen/r2w_card_radius"
                app:cardElevation="4dp"
                app:strokeColor="@color/r2w_premium_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/r2w_card_padding">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/order_detail_summary"
                        android:textAppearance="?attr/textAppearanceTitleMedium"
                        android:textColor="@color/r2w_premium_text" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/order_detail_provider"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/r2w_chip_neutral"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="4dp"
                            android:textAppearance="?attr/textAppearanceLabelSmall" />

                        <TextView
                            android:id="@+id/order_detail_status"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:background="@drawable/r2w_chip_neutral"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="4dp"
                            android:textAppearance="?attr/textAppearanceLabelSmall" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/order_detail_package"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:textAppearance="?attr/textAppearanceBodyLarge"
                        android:textColor="@color/r2w_premium_text" />

                    <TextView
                        android:id="@+id/order_detail_price"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textAppearance="?attr/textAppearanceTitleMedium"
                        android:textColor="@color/r2w_premium_text" />

                    <TextView
                        android:id="@+id/order_detail_number"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="@color/r2w_premium_muted" />

                    <TextView
                        android:id="@+id/order_detail_created"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="@color/r2w_premium_muted" />

                    <TextView
                        android:id="@+id/order_detail_esim_id"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="@color/r2w_premium_muted" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>


            <com.google.android.material.card.MaterialCardView
                android:id="@+id/order_detail_timeline_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@color/r2w_premium_surface"
                app:cardCornerRadius="@dimen/r2w_card_radius"
                app:cardElevation="4dp"
                app:strokeColor="@color/r2w_premium_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/r2w_card_padding">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Order Timeline"
                        android:textAppearance="?attr/textAppearanceTitleMedium"
                        android:textColor="@color/r2w_premium_text" />

                    <TextView
                        android:id="@+id/order_timeline_created"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="@color/r2w_premium_muted" />

                    <TextView
                        android:id="@+id/order_timeline_payment"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="@color/r2w_premium_muted" />

                    <TextView
                        android:id="@+id/order_timeline_provider"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="@color/r2w_premium_muted" />

                    <TextView
                        android:id="@+id/order_timeline_esim"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="@color/r2w_premium_muted" />

                    <TextView
                        android:id="@+id/order_timeline_qr"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="@color/r2w_premium_muted" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>


            <com.google.android.material.card.MaterialCardView
                android:id="@+id/order_detail_customer_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:visibility="gone"
                app:cardBackgroundColor="@color/r2w_premium_surface"
                app:cardCornerRadius="@dimen/r2w_card_radius"
                app:cardElevation="4dp"
                app:strokeColor="@color/r2w_premium_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/r2w_card_padding">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/order_detail_customer_info"
                        android:textAppearance="?attr/textAppearanceTitleMedium"
                        android:textColor="@color/r2w_premium_text" />

                    <TextView
                        android:id="@+id/order_detail_customer_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="@color/r2w_premium_muted" />

                    <TextView
                        android:id="@+id/order_detail_customer_phone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="@color/r2w_premium_muted" />

                    <TextView
                        android:id="@+id/order_detail_customer_email"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="@color/r2w_premium_muted" />

                    <TextView
                        android:id="@+id/order_detail_iccid"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="@color/r2w_premium_muted" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>


            <com.google.android.material.card.MaterialCardView
                android:id="@+id/order_detail_renewal_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:visibility="gone"
                app:cardBackgroundColor="@color/r2w_premium_surface"
                app:cardCornerRadius="@dimen/r2w_card_radius"
                app:cardElevation="4dp"
                app:strokeColor="@color/r2w_premium_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/r2w_card_padding">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/order_detail_last_renewal"
                        android:textAppearance="?attr/textAppearanceTitleMedium"
                        android:textColor="@color/r2w_premium_text" />

                    <TextView
                        android:id="@+id/order_detail_renewal_details"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="@color/r2w_premium_muted" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>


            <com.google.android.material.button.MaterialButton
                android:id="@+id/order_detail_copy_iccid"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="22dp"
                android:backgroundTint="@color/r2w_premium_surface"
                android:text="@string/order_detail_copy_iccid"
                android:textColor="@color/r2w_premium_primary"
                android:visibility="gone"
                app:cornerRadius="@dimen/r2w_button_radius"
                app:strokeColor="@color/r2w_premium_border"
                app:strokeWidth="1dp"
                app:icon="@drawable/ic_task_sim_card_download" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/order_detail_view_esim"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="22dp"
                android:background="@drawable/r2w_premium_primary_button"
                android:text="@string/order_detail_view_esim"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                app:backgroundTint="@null"
                app:cornerRadius="@dimen/r2w_button_radius"
                app:icon="@drawable/ic_task_sim_card_download" />

            <TextView
                android:id="@+id/order_detail_esim_unavailable"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="@string/order_detail_esim_unavailable"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="@color/r2w_premium_muted"
                android:visibility="gone" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
