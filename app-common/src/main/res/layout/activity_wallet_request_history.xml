<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/r2w_premium_bg">

    <include layout="@layout/toolbar_activity" />

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/wallet_request_history_refresh"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <androidx.core.widget.NestedScrollView
            android:id="@+id/wallet_request_history_scroll"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:id="@+id/wallet_request_history_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="@dimen/r2w_screen_padding"
                android:paddingTop="22dp"
                android:paddingBottom="24dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/dashboard_brand"
                    android:textAppearance="?attr/textAppearanceLabelLarge"
                    android:textColor="@color/r2w_premium_primary" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/wallet_request_history_title"
                    android:textAppearance="?attr/textAppearanceDisplaySmall"
                    android:textColor="@color/r2w_premium_text" />

                <TextView
                    android:id="@+id/wallet_request_history_error"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:textColor="@color/r2w_premium_danger"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/wallet_request_history_empty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/r2w_premium_card_soft"
                    android:padding="@dimen/r2w_card_padding"
                    android:text="@string/wallet_request_history_empty"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:textColor="@color/r2w_premium_muted"
                    android:visibility="gone" />

                <LinearLayout
                    android:id="@+id/wallet_request_history_items"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="vertical" />
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
