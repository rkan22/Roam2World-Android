<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/r2w_background">

    <include layout="@layout/toolbar_activity" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/reports_scroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Reports"
                android:textAppearance="?attr/textAppearanceHeadlineSmall"
                android:textColor="@color/r2w_text_primary"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/reports_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Revenue, sales, profit, provider usage and dealer performance"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="@color/r2w_text_secondary" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:baselineAligned="false"
                android:orientation="horizontal">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="112dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    app:cardCornerRadius="16dp"
                    app:strokeColor="@color/r2w_border"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center_vertical"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Revenue"
                            android:textColor="@color/r2w_text_secondary" />

                        <TextView
                            android:id="@+id/reports_revenue"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="--"
                            android:textAppearance="?attr/textAppearanceHeadlineSmall"
                            android:textColor="@color/r2w_text_primary"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/reports_revenue_delta"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Live wallet/orders"
                            android:textColor="@color/r2w_success" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="112dp"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    app:cardCornerRadius="16dp"
                    app:strokeColor="@color/r2w_border"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center_vertical"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Sales"
                            android:textColor="@color/r2w_text_secondary" />

                        <TextView
                            android:id="@+id/reports_sales"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="--"
                            android:textAppearance="?attr/textAppearanceHeadlineSmall"
                            android:textColor="@color/r2w_text_primary"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/reports_sales_delta"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Live orders"
                            android:textColor="@color/r2w_success" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:baselineAligned="false"
                android:orientation="horizontal">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="104dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    app:cardCornerRadius="16dp"
                    app:strokeColor="@color/r2w_border"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center_vertical"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Profit est."
                            android:textColor="@color/r2w_text_secondary" />

                        <TextView
                            android:id="@+id/reports_profit"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="--"
                            android:textAppearance="?attr/textAppearanceTitleLarge"
                            android:textColor="@color/r2w_text_primary"
                            android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="104dp"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    app:cardCornerRadius="16dp"
                    app:strokeColor="@color/r2w_border"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center_vertical"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Active eSIMs"
                            android:textColor="@color/r2w_text_secondary" />

                        <TextView
                            android:id="@+id/reports_active_esims"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="--"
                            android:textAppearance="?attr/textAppearanceTitleLarge"
                            android:textColor="@color/r2w_text_primary"
                            android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="18dp"
                app:strokeColor="@color/r2w_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Sales Overview"
                        android:textAppearance="?attr/textAppearanceTitleMedium"
                        android:textColor="@color/r2w_text_primary"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/reports_sales_overview"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:lineSpacingExtra="4dp"
                        android:text="No sales data yet"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="@color/r2w_text_primary" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="16dp"
                app:strokeColor="@color/r2w_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Provider Usage Breakdown"
                        android:textAppearance="?attr/textAppearanceTitleMedium"
                        android:textColor="@color/r2w_text_primary"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/reports_provider_usage"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:lineSpacingExtra="5dp"
                        android:text="No provider usage yet"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="@color/r2w_text_primary" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="16dp"
                app:strokeColor="@color/r2w_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Dealer Performance"
                        android:textAppearance="?attr/textAppearanceTitleMedium"
                        android:textColor="@color/r2w_text_primary"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/reports_dealer_performance"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Dealer performance data unavailable"
                        android:textColor="@color/r2w_text_primary" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="18dp"
                app:strokeColor="@color/r2w_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Failed Orders"
                        android:textAppearance="?attr/textAppearanceTitleMedium"
                        android:textColor="@color/r2w_text_primary"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/reports_failed_orders"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:lineSpacingExtra="4dp"
                        android:text="No failed order data yet"
                        android:textAppearance="?attr/textAppearanceBodyLarge"
                        android:textColor="@color/r2w_danger" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="18dp"
                app:strokeColor="@color/r2w_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Profit Overview"
                        android:textAppearance="?attr/textAppearanceTitleMedium"
                        android:textColor="@color/r2w_text_primary"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/reports_profit_overview"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:lineSpacingExtra="4dp"
                        android:text="Profit data unavailable"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="@color/r2w_text_primary" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
