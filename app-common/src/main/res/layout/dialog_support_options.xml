<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/r2w_support_dialog_bg"
    android:orientation="vertical"
    android:padding="24dp">

    <FrameLayout
        android:layout_width="86dp"
        android:layout_height="86dp"
        android:layout_gravity="center_horizontal"
        android:background="@drawable/r2w_support_icon_bg">

        <ImageView
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center"
            android:contentDescription="@null"
            android:src="@drawable/ic_support_headset_white" />
    </FrameLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:gravity="center"
        android:text="How can we help?"
        android:textColor="@color/r2w_text_primary"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:lineSpacingExtra="2dp"
        android:text="Choose your preferred support channel. Our team will help you as soon as possible."
        android:textColor="@color/r2w_text_secondary"
        android:textSize="14sp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/support_whatsapp"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="22dp"
        android:background="@drawable/r2w_support_whatsapp_bg"
        android:text="WhatsApp Support"
        android:textAllCaps="false"
        android:textColor="@android:color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        app:backgroundTint="@null"
        app:cornerRadius="16dp"
        app:icon="@drawable/ic_support_whatsapp"
        app:iconGravity="textStart"
        app:iconPadding="10dp"
        app:iconTint="@android:color/white" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/support_email"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/r2w_support_email_bg"
        android:text="Email Support"
        android:textAllCaps="false"
        android:textColor="#0B63E5"
        android:textSize="16sp"
        android:textStyle="bold"
        app:backgroundTint="@null"
        app:cornerRadius="16dp"
        app:icon="@drawable/ic_support_email_blue"
        app:iconGravity="textStart"
        app:iconPadding="10dp"
        app:iconTint="#0B63E5" />

    <TextView
        android:id="@+id/support_cancel"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginTop="10dp"
        android:gravity="center"
        android:text="Cancel"
        android:textColor="@color/r2w_text_secondary"
        android:textSize="15sp"
        android:textStyle="bold" />
</LinearLayout>
