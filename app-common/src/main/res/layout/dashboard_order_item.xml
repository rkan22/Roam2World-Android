<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="@color/r2w_premium_surface"
    app:cardCornerRadius="22dp"
    app:cardElevation="2dp"
    app:strokeColor="@color/r2w_premium_border"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="86dp"
        android:paddingHorizontal="18dp"
        android:paddingVertical="16dp">

        <TextView
            android:id="@+id/order_icon"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/r2w_order_icon_bg"
                        android:gravity="center"
            android:text=""
            android:textColor="@color/r2w_premium_primary"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/order_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="10dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textAppearance="?attr/textAppearanceTitleSmall"
            android:textColor="@color/r2w_premium_text"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@id/order_amount"
            app:layout_constraintStart_toEndOf="@id/order_icon"
            app:layout_constraintTop_toTopOf="@id/order_icon" />

        <TextView
            android:id="@+id/order_subtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="5dp"
            android:layout_marginEnd="10dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:textColor="@color/r2w_premium_primary"
            app:layout_constraintEnd_toStartOf="@id/order_status"
            app:layout_constraintStart_toEndOf="@id/order_icon"
            app:layout_constraintTop_toBottomOf="@id/order_title" />

        <TextView
            android:id="@+id/order_amount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="?attr/textAppearanceTitleSmall"
            android:textColor="@color/r2w_premium_success"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/order_title" />

        <TextView
            android:id="@+id/order_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/r2w_order_status_chip"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:textAppearance="?attr/textAppearanceLabelSmall"
            android:textColor="@color/r2w_premium_muted"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/order_subtitle" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
