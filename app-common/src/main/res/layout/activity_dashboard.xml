<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/r2w_premium_bg">

    <include layout="@layout/toolbar_activity" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/dashboard_scroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@id/dashboard_bottom_nav"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <LinearLayout
            android:id="@+id/dashboard_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="28dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="188dp"
                android:layout_marginHorizontal="0dp"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardCornerRadius="0dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@color/r2w_premium_bg"
                    android:paddingHorizontal="@dimen/r2w_screen_padding"
                    android:paddingTop="22dp"
                    android:paddingBottom="28dp">

                    <ImageView
                        android:id="@+id/dashboard_brand_icon"
                        android:layout_width="46dp"
                        android:layout_height="46dp"
                        android:background="@drawable/r2w_premium_icon_box"
                        android:contentDescription="@string/login_logo_content_description"
                        android:padding="9dp"
                        android:src="@drawable/ic_roam2world_logo"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="@color/r2w_premium_primary" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="Roam2World B2B"
                        android:textAppearance="?attr/textAppearanceHeadlineSmall"
                        android:textColor="@color/r2w_premium_text"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toBottomOf="@id/dashboard_brand_icon"
                        app:layout_constraintEnd_toStartOf="@id/dashboard_profile_dot"
                        app:layout_constraintStart_toEndOf="@id/dashboard_brand_icon"
                        app:layout_constraintTop_toTopOf="@id/dashboard_brand_icon" />

                    <TextView
                        android:id="@+id/dashboard_profile_dot"
                        android:layout_width="46dp"
                        android:layout_height="46dp"
                        android:background="@drawable/r2w_premium_icon_box"
                        android:gravity="center"
                        android:text="R2W"
                        android:textAppearance="?attr/textAppearanceLabelSmall"
                        android:textColor="@color/r2w_premium_primary"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/dashboard_greeting"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="30dp"
                        android:maxLines="2"
                        android:textAppearance="?attr/textAppearanceHeadlineMedium"
                        android:textColor="@color/r2w_premium_text"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/dashboard_brand_icon" />

                    <TextView
                        android:id="@+id/dashboard_account"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:ellipsize="end"
                        android:maxLines="2"
                        android:textAppearance="?attr/textAppearanceBodyLarge"
                        android:textColor="@color/r2w_premium_muted"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/dashboard_greeting" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp">

                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/dashboard_progress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:indeterminate="true"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/dashboard_error"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:textColor="@color/r2w_premium_danger"
                    android:visibility="gone" />

                
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/dashboard_wallet_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@color/r2w_premium_surface"
                app:cardCornerRadius="22dp"
                app:cardElevation="3dp"
                app:strokeColor="@color/r2w_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <FrameLayout
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            android:background="@drawable/r2w_wallet_icon_box">

                            <ImageView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:layout_gravity="center"
                                android:contentDescription="Wallet"
                                android:src="@drawable/ic_dashboard_wallet" />
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Wallet Balance"
                                android:textAppearance="?attr/textAppearanceTitleMedium"
                                android:textColor="@color/r2w_text_secondary" />

                            <TextView
                                android:id="@+id/dashboard_wallet_balance"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="0.00"
                                android:textAppearance="?attr/textAppearanceDisplaySmall"
                                android:textColor="@color/r2w_premium_primary"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <ImageButton
                            android:id="@+id/dashboard_wallet_eye_button"
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:background="@drawable/r2w_wallet_icon_box"
                            android:contentDescription="Show balance"
                            android:padding="14dp"
                            android:src="@drawable/ic_dashboard_eye" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="16dp"
                        android:background="@color/r2w_border" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:gravity="end"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/dashboard_request_balance"
                            android:layout_width="wrap_content"
                            android:layout_height="48dp"
                            android:background="@drawable/r2w_dashboard_request_balance_button"
                            android:minWidth="0dp"
                            android:minHeight="0dp"
                            android:paddingHorizontal="16dp"
                            android:text="Request Balance"
                            android:textAllCaps="false"
                            android:textColor="@android:color/white"
                            android:textStyle="bold"
                            app:backgroundTint="@null"
                            app:cornerRadius="14dp"
                            app:icon="@drawable/request_balance"
                            app:iconGravity="textStart"
                            app:iconPadding="8dp"
                            app:iconSize="22dp"
                            app:iconTint="@android:color/white" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>


                <LinearLayout
                    android:id="@+id/dashboard_dynamic_kpis"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="16dp"
                    android:gravity="center_horizontal"
                    android:orientation="vertical" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="16dp"
                    android:baselineAligned="false"
                    android:orientation="horizontal"
                    android:visibility="gone">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="126dp"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        app:cardBackgroundColor="@color/r2w_premium_surface"
                        app:cardCornerRadius="@dimen/r2w_card_radius"
                        app:cardElevation="4dp"
                        app:strokeColor="@color/r2w_premium_border"
                        app:strokeWidth="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center_vertical"
                            android:orientation="vertical"
                            android:padding="18dp">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Monthly Sales"
                                android:textAppearance="?attr/textAppearanceLabelMedium"
                                android:textColor="@color/r2w_premium_muted" />

                            <TextView
                                android:id="@+id/dashboard_orders_summary"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:maxLines="1"
                                android:textAppearance="?attr/textAppearanceHeadlineMedium"
                                android:textColor="@color/r2w_premium_text"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="126dp"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        app:cardBackgroundColor="@color/r2w_premium_surface"
                        app:cardCornerRadius="@dimen/r2w_card_radius"
                        app:cardElevation="4dp"
                        app:strokeColor="@color/r2w_premium_border"
                        app:strokeWidth="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center_vertical"
                            android:orientation="vertical"
                            android:padding="18dp">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Active eSIMs"
                                android:textAppearance="?attr/textAppearanceLabelMedium"
                                android:textColor="@color/r2w_premium_muted" />

                            <TextView
                                android:id="@+id/dashboard_active_esims"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:ellipsize="end"
                                android:maxLines="1"
                                android:textAppearance="?attr/textAppearanceHeadlineMedium"
                                android:textColor="@color/r2w_premium_text"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/dashboard_dealer_summary_card"
                    android:layout_width="match_parent"
                    android:layout_gravity="center_horizontal"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:visibility="gone"
                    app:cardBackgroundColor="@color/r2w_premium_surface"
                    app:cardCornerRadius="@dimen/r2w_card_radius"
                    app:cardElevation="4dp"
                    app:strokeColor="@color/r2w_premium_border"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Dealer Network"
                            android:textAppearance="?attr/textAppearanceLabelLarge"
                            android:textColor="@color/r2w_premium_muted" />

                        <TextView
                            android:id="@+id/dashboard_dealer_summary"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:textAppearance="?attr/textAppearanceTitleMedium"
                            android:textColor="@color/r2w_premium_text"
                            android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="28dp"
                    android:text="Quick Actions"
                    android:textAppearance="?attr/textAppearanceTitleLarge"
                    android:textColor="@color/r2w_premium_text"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:baselineAligned="false"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/dashboard_browse_packages"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="82dp"
                            android:layout_marginEnd="6dp"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="Buy eSIM"
                            android:textAlignment="center"
                            android:textColor="@color/r2w_premium_text"
                            app:cornerRadius="20dp"
                            app:icon="@drawable/ic_packages"
                            app:iconGravity="top"
                            app:iconPadding="6dp"
                            app:strokeColor="@color/r2w_premium_border" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:baselineAligned="false"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/dashboard_view_history"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="82dp"
                            android:layout_marginEnd="6dp"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="eSIM History"
                            android:textAlignment="center"
                            android:textColor="@color/r2w_premium_text"
                            app:cornerRadius="20dp"
                            app:icon="@drawable/ic_checkmark_outline"
                            app:iconGravity="top"
                            app:iconPadding="6dp"
                            app:strokeColor="@color/r2w_premium_border" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/dashboard_manage_dealers"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="82dp"
                            android:layout_marginStart="6dp"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="Dealers"
                            android:textAlignment="center"
                            android:textColor="@color/r2w_premium_text"
                            android:visibility="gone"
                            app:cornerRadius="20dp"
                            app:icon="@drawable/ic_group"
                            app:iconGravity="top"
                            app:iconPadding="6dp"
                            app:strokeColor="@color/r2w_premium_border" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="28dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Recent Purchases"
                        android:textAppearance="?attr/textAppearanceTitleLarge"
                        android:textColor="@color/r2w_premium_text"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="View All"
                        android:textAppearance="?attr/textAppearanceLabelLarge"
                        android:textColor="@color/r2w_premium_primary"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/dashboard_orders"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="vertical" />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/dashboard_bottom_nav"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/r2w_premium_surface"
        app:labelVisibilityMode="labeled"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:menu="@menu/activity_dashboard_bottom" />
</androidx.constraintlayout.widget.ConstraintLayout>
