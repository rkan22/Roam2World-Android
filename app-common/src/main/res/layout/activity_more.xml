<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/r2w_premium_bg">

    <include layout="@layout/toolbar_activity" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/more_scroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/more_bottom_nav"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/r2w_screen_padding"
            android:paddingTop="20dp"
            android:paddingBottom="30dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="More"
                android:textAppearance="?attr/textAppearanceHeadlineLarge"
                android:textColor="@color/r2w_premium_text"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Roam2World B2B telecom control center"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="@color/r2w_premium_muted" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardCornerRadius="22dp"
                app:cardElevation="3dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/dashboard_hero_gradient"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="58dp"
                        android:layout_height="58dp"
                        android:background="@drawable/r2w_premium_icon_box"
                        android:backgroundTint="#33FFFFFF"
                        android:gravity="center"
                        android:text="R2W"
                        android:textColor="@android:color/white"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Roam2World B2B"
                            android:textAppearance="?attr/textAppearanceTitleMedium"
                            android:textColor="@android:color/white"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Admin / Reseller / Dealer workspace"
                            android:textAppearance="?attr/textAppearanceBodyMedium"
                            android:textColor="#DDEBFF" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Business Operations"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:textColor="@color/r2w_premium_text"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:baselineAligned="false"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/more_customers"
                android:background="@drawable/r2w_more_menu_button"
                                                android:layout_width="0dp"
                        android:layout_height="86dp"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="Customers\nCRM"
                        android:textAlignment="center"
                        app:cornerRadius="22dp"
                        app:icon="@drawable/ic_person"
                        app:iconGravity="top"
                        app:iconPadding="6dp" 
                        app:backgroundTint="@null"
                        android:textColor="@color/r2w_premium_text"
                        android:textAllCaps="false"
                        android:textStyle="bold"
                        app:iconTint="@color/r2w_premium_primary"
                        app:strokeColor="#E3EBF7"
                        app:strokeWidth="0dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/more_esim_history"
                android:background="@drawable/r2w_more_menu_button"
                                                android:layout_width="0dp"
                        android:layout_height="86dp"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="Orders\nHistory"
                        android:textAlignment="center"
                        app:cornerRadius="22dp"
                        app:icon="@drawable/ic_checkmark_outline"
                        app:iconGravity="top"
                        app:iconPadding="6dp" 
                        app:backgroundTint="@null"
                        android:textColor="@color/r2w_premium_text"
                        android:textAllCaps="false"
                        android:textStyle="bold"
                        app:iconTint="@color/r2w_premium_primary"
                        app:strokeColor="#E3EBF7"
                        app:strokeWidth="0dp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:baselineAligned="false"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/more_openeuicc"
                android:background="@drawable/r2w_more_menu_button"
                                                android:layout_width="0dp"
                        android:layout_height="86dp"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="OpenEUICC\nInstall"
                        android:textAlignment="center"
                        app:cornerRadius="22dp"
                        app:icon="@drawable/ic_task_sim_card_download"
                        app:iconGravity="top"
                        app:iconPadding="6dp" 
                        app:backgroundTint="@null"
                        android:textColor="@color/r2w_premium_text"
                        android:textAllCaps="false"
                        android:textStyle="bold"
                        app:iconTint="@color/r2w_premium_primary"
                        app:strokeColor="#E3EBF7"
                        app:strokeWidth="0dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/more_tgt_recharge"
                android:background="@drawable/r2w_more_menu_button"
                                                android:layout_width="0dp"
                        android:layout_height="86dp"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="Orange\nRecharge"
                        android:textAlignment="center"
                        app:cornerRadius="22dp"
                        app:icon="@drawable/ic_packages"
                        app:iconGravity="top"
                        app:iconPadding="6dp" 
                        app:backgroundTint="@null"
                        android:textColor="@color/r2w_premium_text"
                        android:textAllCaps="false"
                        android:textStyle="bold"
                        app:iconTint="@color/r2w_premium_primary"
                        app:strokeColor="#E3EBF7"
                        app:strokeWidth="0dp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:baselineAligned="false"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/more_vodafone_renewal"
                android:background="@drawable/r2w_more_menu_button"
                                                android:layout_width="0dp"
                        android:layout_height="86dp"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="Vodafone\nRecharge"
                        android:textAlignment="center"
                        app:cornerRadius="22dp"
                        app:icon="@drawable/ic_packages"
                        app:iconGravity="top"
                        app:iconPadding="6dp" 
                        app:backgroundTint="@null"
                        android:textColor="@color/r2w_premium_text"
                        android:textAllCaps="false"
                        android:textStyle="bold"
                        app:iconTint="@color/r2w_premium_primary"
                        app:strokeColor="#E3EBF7"
                        app:strokeWidth="0dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/more_orders"
                android:background="@drawable/r2w_more_menu_button"
                                                android:layout_width="0dp"
                        android:layout_height="86dp"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="Order\nStatus"
                        android:textAlignment="center"
                        app:cornerRadius="22dp"
                        app:icon="@drawable/ic_wallet"
                        app:iconGravity="top"
                        app:iconPadding="6dp" 
                        app:backgroundTint="@null"
                        android:textColor="@color/r2w_premium_text"
                        android:textAllCaps="false"
                        android:textStyle="bold"
                        app:iconTint="@color/r2w_premium_primary"
                        app:strokeColor="#E3EBF7"
                        app:strokeWidth="0dp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:baselineAligned="false"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/more_reports"
                android:background="@drawable/r2w_more_menu_button"
                                                android:layout_width="0dp"
                        android:layout_height="86dp"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="Reports\nDashboard"
                        android:textAlignment="center"
                        app:cornerRadius="22dp"
                        app:icon="@drawable/ic_bar_chart"
                        app:iconGravity="top"
                        app:iconPadding="6dp" 
                        app:backgroundTint="@null"
                        android:textColor="@color/r2w_premium_text"
                        android:textAllCaps="false"
                        android:textStyle="bold"
                        app:iconTint="@color/r2w_premium_primary"
                        app:strokeColor="#E3EBF7"
                        app:strokeWidth="0dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/more_support"
                android:background="@drawable/r2w_more_menu_button"
                                                android:layout_width="0dp"
                        android:layout_height="86dp"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="Support\nHelp"
                        android:textAlignment="center"
                        app:cornerRadius="22dp"
                        app:icon="@drawable/ic_support"
                        app:iconGravity="top"
                        app:iconPadding="6dp" 
                        app:backgroundTint="@null"
                        android:textColor="@color/r2w_premium_text"
                        android:textAllCaps="false"
                        android:textStyle="bold"
                        app:iconTint="@color/r2w_premium_primary"
                        app:strokeColor="#E3EBF7"
                        app:strokeWidth="0dp"/>
                </LinearLayout>
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/more_notifications"
                android:background="@drawable/r2w_more_menu_wide_button"
                                android:layout_width="match_parent"
                android:layout_height="74dp"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:text="Notifications\nInbox"
                android:textAlignment="center"
                app:cornerRadius="22dp"
                app:icon="@drawable/ic_support"
                app:iconGravity="top"
                app:iconPadding="6dp" 
                        app:backgroundTint="@null"
                        android:textColor="@color/r2w_premium_text"
                        android:textAllCaps="false"
                        android:textStyle="bold"
                        app:iconTint="@color/r2w_premium_primary"
                        app:strokeColor="#E3EBF7"
                        app:strokeWidth="0dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/more_tgt_check_gb"
                android:background="@drawable/r2w_more_menu_wide_button"
                                android:layout_width="match_parent"
                android:layout_height="74dp"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:text="Orange\nCheck GB"
                android:textAlignment="center"
                app:cornerRadius="22dp"
                app:icon="@drawable/ic_packages"
                app:iconGravity="top"
                app:iconPadding="6dp" 
                        app:backgroundTint="@null"
                        android:textColor="@color/r2w_premium_text"
                        android:textAllCaps="false"
                        android:textStyle="bold"
                        app:iconTint="@color/r2w_premium_primary"
                        app:strokeColor="#E3EBF7"
                        app:strokeWidth="0dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Account"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:textColor="@color/r2w_premium_text"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:baselineAligned="false"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/more_profile"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="74dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Profile"
                    app:cornerRadius="@dimen/r2w_card_radius"
                    app:icon="@drawable/ic_person"
                    app:iconGravity="top" 
                        android:backgroundTint="@color/r2w_premium_surface"
                        android:textColor="@color/r2w_premium_text"
                        app:iconTint="@color/r2w_premium_primary"
                        app:strokeColor="@color/r2w_premium_border"
                        app:strokeWidth="1dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/more_settings"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="74dp"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Settings"
                    app:cornerRadius="@dimen/r2w_card_radius"
                    app:icon="@drawable/ic_settings"
                    app:iconGravity="top" 
                        android:backgroundTint="@color/r2w_premium_surface"
                        android:textColor="@color/r2w_premium_text"
                        app:iconTint="@color/r2w_premium_primary"
                        app:strokeColor="@color/r2w_premium_border"
                        app:strokeWidth="1dp"/>
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/more_logout"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="18dp"
                android:gravity="center_vertical"
                android:backgroundTint="@color/r2w_premium_surface"
                android:text="@string/logout"
                android:textColor="@color/r2w_premium_danger"
                app:strokeColor="@color/r2w_premium_danger"
                app:strokeWidth="1dp"
                app:cornerRadius="@dimen/r2w_button_radius"
                app:icon="@drawable/ic_logout"
                app:iconTint="@color/r2w_premium_danger" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/more_bottom_nav"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/r2w_premium_surface"
        app:labelVisibilityMode="labeled"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:menu="@menu/activity_dashboard_bottom" />
</androidx.constraintlayout.widget.ConstraintLayout>
