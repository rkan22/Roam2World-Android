<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/r2w_background">

    <include layout="@layout/toolbar_activity" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/more_scroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/more_bottom_nav"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="More"
                android:textAppearance="?attr/textAppearanceHeadlineSmall"
                android:textColor="@color/r2w_text_primary"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Roam2World B2B telecom control center"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="@color/r2w_text_secondary" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardCornerRadius="22dp"
                app:cardElevation="5dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/dashboard_hero_gradient"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="58dp"
                        android:layout_height="58dp"
                        android:background="@drawable/wallet_request_status_badge"
                        android:backgroundTint="#33FFFFFF"
                        android:gravity="center"
                        android:text="R2W"
                        android:textColor="@android:color/white"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Roam2World B2B"
                            android:textAppearance="?attr/textAppearanceTitleMedium"
                            android:textColor="@android:color/white"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Admin • Reseller • Dealer workspace"
                            android:textAppearance="?attr/textAppearanceBodyMedium"
                            android:textColor="#DDEBFF" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Business Operations"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:textColor="@color/r2w_text_primary"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:baselineAligned="false"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/more_customers"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="86dp"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="Customers\nRecords"
                        android:textAlignment="center"
                        app:cornerRadius="18dp"
                        app:icon="@drawable/ic_person"
                        app:iconGravity="top"
                        app:iconPadding="6dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/more_esim_history"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="86dp"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="eSIM History\nPurchases"
                        android:textAlignment="center"
                        app:cornerRadius="18dp"
                        app:icon="@drawable/ic_checkmark_outline"
                        app:iconGravity="top"
                        app:iconPadding="6dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:baselineAligned="false"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/more_openeuicc"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="86dp"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="OpenEUICC\nProfiles"
                        android:textAlignment="center"
                        app:cornerRadius="18dp"
                        app:icon="@drawable/ic_task_sim_card_download"
                        app:iconGravity="top"
                        app:iconPadding="6dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/more_tgt_recharge"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="86dp"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="TGT SIM\nRecharge"
                        android:textAlignment="center"
                        app:cornerRadius="18dp"
                        app:icon="@drawable/ic_packages"
                        app:iconGravity="top"
                        app:iconPadding="6dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:baselineAligned="false"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/more_vodafone_renewal"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="86dp"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="Vodafone\nRenewal"
                        android:textAlignment="center"
                        app:cornerRadius="18dp"
                        app:icon="@drawable/ic_packages"
                        app:iconGravity="top"
                        app:iconPadding="6dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/more_orders"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="86dp"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="Orders\nStatus"
                        android:textAlignment="center"
                        app:cornerRadius="18dp"
                        app:icon="@drawable/ic_wallet"
                        app:iconGravity="top"
                        app:iconPadding="6dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:baselineAligned="false"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/more_reports"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="86dp"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="Reports\nAnalytics"
                        android:textAlignment="center"
                        app:cornerRadius="18dp"
                        app:icon="@drawable/ic_bar_chart"
                        app:iconGravity="top"
                        app:iconPadding="6dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/more_support"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="86dp"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="Support\nHelpdesk"
                        android:textAlignment="center"
                        app:cornerRadius="18dp"
                        app:icon="@drawable/ic_support"
                        app:iconGravity="top"
                        app:iconPadding="6dp" />
                </LinearLayout>
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/more_notifications"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="74dp"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:text="Notifications\nInbox"
                android:textAlignment="center"
                app:cornerRadius="18dp"
                app:icon="@drawable/ic_support"
                app:iconGravity="top"
                app:iconPadding="6dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Account"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:textColor="@color/r2w_text_primary"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:baselineAligned="false"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/more_profile"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="74dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Profile"
                    app:cornerRadius="18dp"
                    app:icon="@drawable/ic_person"
                    app:iconGravity="top" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/more_settings"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="74dp"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Settings"
                    app:cornerRadius="18dp"
                    app:icon="@drawable/ic_settings"
                    app:iconGravity="top" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/more_logout"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="18dp"
                android:gravity="center_vertical"
                android:text="@string/logout"
                android:textColor="@color/r2w_danger"
                app:cornerRadius="16dp"
                app:icon="@drawable/ic_logout"
                app:iconTint="@color/r2w_danger" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/more_bottom_nav"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/r2w_card"
        app:labelVisibilityMode="labeled"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:menu="@menu/activity_dashboard_bottom" />
</androidx.constraintlayout.widget.ConstraintLayout>
