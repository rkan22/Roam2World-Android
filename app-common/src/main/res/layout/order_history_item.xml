<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="0dp"
    android:layout_marginTop="8dp"
    android:layout_marginEnd="0dp"
    android:layout_marginBottom="8dp"
    app:cardBackgroundColor="@android:color/white"
    app:cardCornerRadius="14dp"
    app:cardElevation="0dp"
    app:strokeColor="#E3E8EF"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="164dp"
        android:paddingStart="14dp"
        android:paddingTop="12dp"
        android:paddingEnd="14dp"
        android:paddingBottom="12dp">

        <FrameLayout
            android:id="@+id/history_provider_box"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:background="@drawable/r2w_order_icon_circle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/history_provider_logo"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center"
                android:adjustViewBounds="true"
                android:contentDescription="@null"
                android:scaleType="centerInside"
                android:src="@drawable/r2w_order_doc_icon" />

            <TextView
                android:id="@+id/history_provider"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:textColor="#0B6BFF"
                android:textSize="10sp"
                android:textStyle="bold"
                android:visibility="gone" />
        </FrameLayout>

        <TextView
            android:id="@+id/history_order_number"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="10dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="#08224A"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@id/history_status"
            app:layout_constraintStart_toEndOf="@id/history_provider_box"
            app:layout_constraintTop_toTopOf="@id/history_provider_box" />

        <TextView
            android:id="@+id/history_created_date"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="5dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="#778197"
            android:textSize="13sp"
            app:layout_constraintEnd_toStartOf="@id/history_status"
            app:layout_constraintStart_toEndOf="@id/history_provider_box"
            app:layout_constraintTop_toBottomOf="@id/history_order_number" />

        <TextView
            android:id="@+id/history_status"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:gravity="center"
            android:maxLines="1"
            android:minWidth="88dp"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:textSize="13sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/history_provider_box" />

        <View
            android:id="@+id/history_divider_top"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_marginTop="10dp"
            android:background="#E8ECF2"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@id/history_order_number"
            app:layout_constraintTop_toBottomOf="@id/history_created_date" />

        <FrameLayout
            android:id="@+id/history_package_icon_box"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/r2w_order_icon_circle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/history_divider_top">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center"
                android:contentDescription="@null"
                android:src="@drawable/r2w_order_globe_icon" />
        </FrameLayout>

        <TextView
            android:id="@+id/history_package_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="8dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="#08224A"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/history_package_icon_box"
            app:layout_constraintEnd_toStartOf="@id/history_price"
            app:layout_constraintStart_toEndOf="@id/history_package_icon_box"
            app:layout_constraintTop_toTopOf="@id/history_package_icon_box" />

        <TextView
            android:id="@+id/history_price"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:maxLines="1"
            android:textColor="#08224A"
            android:textSize="17sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/history_package_icon_box"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/history_package_icon_box" />

        <View
            android:id="@+id/history_divider_bottom"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_marginTop="10dp"
            android:background="#E8ECF2"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@id/history_package_name"
            app:layout_constraintTop_toBottomOf="@id/history_divider_bottom" />

        <FrameLayout
            android:id="@+id/history_customer_icon_box"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/r2w_order_icon_circle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/history_package_icon_box">

            <ImageView
                android:id="@+id/history_customer_avatar"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center"
                android:background="@android:color/transparent"
                android:contentDescription="@null"
                android:src="@drawable/r2w_order_user_icon" />
        </FrameLayout>

        <TextView
            android:id="@+id/history_customer_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="Customer:"
            android:textColor="#5F6B7D"
            android:textSize="13sp"
            app:layout_constraintEnd_toStartOf="@id/history_view_detail"
            app:layout_constraintStart_toEndOf="@id/history_customer_icon_box"
            app:layout_constraintTop_toTopOf="@id/history_customer_icon_box" />

        <TextView
            android:id="@+id/history_customer_phone"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="2dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="#08224A"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@id/history_view_detail"
            app:layout_constraintStart_toEndOf="@id/history_customer_icon_box"
            app:layout_constraintTop_toBottomOf="@id/history_customer_label" />

        <ImageView
            android:id="@+id/history_view_detail"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:contentDescription="@null"
            android:src="@drawable/r2w_ic_chevron_right"
            app:tint="#0B6BFF"
            app:layout_constraintBottom_toBottomOf="@id/history_customer_icon_box"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/history_customer_icon_box" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
