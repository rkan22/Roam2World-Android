<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/r2w_premium_bg">

    <include layout="@layout/toolbar_activity" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/vodafone_renewal_scroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/r2w_screen_padding"
            android:paddingTop="20dp"
            android:paddingBottom="30dp">

            <ImageView
                android:layout_width="76dp"
                android:layout_height="52dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="10dp"
                android:adjustViewBounds="true"
                android:contentDescription="Vodafone"
                android:scaleType="fitCenter"
                android:src="@drawable/vodafone_logo" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Vodafone Recharge"
                android:textAppearance="?attr/textAppearanceHeadlineLarge"
                android:textColor="@color/r2w_premium_text"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Renew Vodafone eSIM packages with ICCID"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="@color/r2w_premium_muted" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="26dp"
                android:text="1. Vodafone eSIM ICCID"
                android:textAppearance="?attr/textAppearanceTitleLarge"
                android:textColor="@color/r2w_premium_text"
                android:textStyle="bold" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/vodafone_search_iccid_layout"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Vodafone eSIM ICCID"
                app:boxBackgroundColor="@color/r2w_premium_surface"
                app:boxCornerRadiusBottomEnd="18dp"
                app:boxCornerRadiusBottomStart="18dp"
                app:boxCornerRadiusTopEnd="18dp"
                app:boxCornerRadiusTopStart="18dp"
                app:boxStrokeColor="@color/r2w_premium_border"
                app:hintTextColor="@color/r2w_premium_muted"
                app:startIconDrawable="@drawable/ic_task_sim_card_download">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/vodafone_search_iccid"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:maxLines="1" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/vodafone_search_button"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:visibility="gone"
                android:text="Find Vodafone eSIM" />

            <TextView
                android:id="@+id/vodafone_search_result"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/r2w_vodafone_selected_card"
                android:padding="16dp"
                android:text="Enter ICCID, choose package, then continue."
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="@color/r2w_premium_muted"
                android:visibility="gone" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="2. Choose eSIM Data"
                android:textAppearance="?attr/textAppearanceTitleLarge"
                android:textColor="@color/r2w_premium_text"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:baselineAligned="false"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/vodafone_package_200gb"
                    android:layout_width="0dp"
                    android:layout_height="82dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/r2w_vodafone_card_selected"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="200GB"
                    android:textAppearance="?attr/textAppearanceHeadlineSmall"
                    android:textColor="#E60000"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/vodafone_package_400gb"
                    android:layout_width="0dp"
                    android:layout_height="82dp"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/r2w_vodafone_card_unselected"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="400GB"
                    android:textAppearance="?attr/textAppearanceHeadlineSmall"
                    android:textColor="@color/r2w_premium_text" />
            </LinearLayout>

            <TextView
                android:id="@+id/vodafone_package_500gb"
                android:layout_width="match_parent"
                android:layout_height="82dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/r2w_vodafone_card_unselected"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="500GB"
                android:textAppearance="?attr/textAppearanceHeadlineSmall"
                android:textColor="@color/r2w_premium_text" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:background="@drawable/r2w_vodafone_selected_card"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp">

                <ImageView
                    android:layout_width="58dp"
                    android:layout_height="58dp"
                    android:adjustViewBounds="true"
                    android:contentDescription="Vodafone"
                    android:scaleType="fitCenter"
                    android:src="@drawable/vodafone_logo" />

                <TextView
                    android:id="@+id/vodafone_selected_package"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:text="Vodafone eSIM Renewal\n200GB"
                    android:textAppearance="?attr/textAppearanceTitleSmall"
                    android:textColor="@color/r2w_premium_text"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="3. Customer Information"
                android:textAppearance="?attr/textAppearanceTitleLarge"
                android:textColor="@color/r2w_premium_text"
                android:textStyle="bold" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/vodafone_customer_name_layout"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Customer name"
                app:boxBackgroundColor="@color/r2w_premium_surface"
                app:boxCornerRadiusBottomEnd="18dp"
                app:boxCornerRadiusBottomStart="18dp"
                app:boxCornerRadiusTopEnd="18dp"
                app:boxCornerRadiusTopStart="18dp"
                app:boxStrokeColor="@color/r2w_premium_border"
                app:hintTextColor="@color/r2w_premium_muted"
                app:startIconDrawable="@drawable/ic_person">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/vodafone_customer_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPersonName"
                    android:maxLines="1" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/vodafone_customer_phone_layout"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Phone number"
                app:boxBackgroundColor="@color/r2w_premium_surface"
                app:boxCornerRadiusBottomEnd="18dp"
                app:boxCornerRadiusBottomStart="18dp"
                app:boxCornerRadiusTopEnd="18dp"
                app:boxCornerRadiusTopStart="18dp"
                app:boxStrokeColor="@color/r2w_premium_border"
                app:hintTextColor="@color/r2w_premium_muted"
                app:startIconDrawable="@drawable/ic_phone">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/vodafone_customer_phone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="phone"
                    android:maxLines="1" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/vodafone_customer_email_layout"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Email optional"
                app:boxBackgroundColor="@color/r2w_premium_surface"
                app:boxCornerRadiusBottomEnd="18dp"
                app:boxCornerRadiusBottomStart="18dp"
                app:boxCornerRadiusTopEnd="18dp"
                app:boxCornerRadiusTopStart="18dp"
                app:boxStrokeColor="@color/r2w_premium_border"
                app:hintTextColor="@color/r2w_premium_muted">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/vodafone_customer_email"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textEmailAddress"
                    android:maxLines="1" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/vodafone_renew_button"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="22dp"
                android:background="@drawable/r2w_vodafone_primary_button"
                android:enabled="true"
                android:text="Continue Renewal"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                app:backgroundTint="@null"
                app:cornerRadius="16dp" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
