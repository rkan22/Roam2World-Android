<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/r2w_premium_bg">

    <include layout="@layout/toolbar_activity" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/vodafone_renewal_scroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/r2w_screen_padding"
            android:paddingTop="20dp"
            android:paddingBottom="30dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Vodafone eSIM Renewal"
                android:textAppearance="?attr/textAppearanceHeadlineLarge"
                android:textColor="@color/r2w_premium_text"
                android:textStyle="bold"
                android:textAllCaps="false" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Search by ICCID. Renewal is available only before the eSIM expires."
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="@color/r2w_premium_muted" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/vodafone_search_iccid_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:hint="Search ICCID"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                app:boxBackgroundColor="@color/r2w_premium_surface"
                app:boxCornerRadiusBottomEnd="18dp"
                app:boxCornerRadiusBottomStart="18dp"
                app:boxCornerRadiusTopEnd="18dp"
                app:boxCornerRadiusTopStart="18dp"
                app:boxStrokeColor="@color/r2w_premium_border"
                app:hintTextColor="@color/r2w_premium_muted">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/vodafone_search_iccid"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/vodafone_search_button"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:background="@drawable/r2w_premium_primary_button"
                android:layout_marginTop="14dp"
                android:text="Find Vodafone eSIM"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:textAllCaps="false"
                app:backgroundTint="@null"
                app:cornerRadius="16dp" />

            <TextView
                android:id="@+id/vodafone_search_result"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/r2w_recharge_info_card"
                android:padding="@dimen/r2w_card_padding"
                android:text="Enter ICCID to search Vodafone eSIMs."
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="@color/r2w_premium_muted" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Renewal Package"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:textColor="@color/r2w_premium_text"
                android:textStyle="bold"
                android:textAllCaps="false" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:scrollbars="none">

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/vodafone_package_group"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:selectionRequired="true"
                    app:singleSelection="true">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/vodafone_package_200gb"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        android:text="200GB / 30D"
                    android:textColor="@color/r2w_premium_primary"
                    app:chipBackgroundColor="#F8FAFF"
                    app:chipCornerRadius="16dp"
                    app:chipStrokeColor="#BFD4FF"
                    app:chipStrokeWidth="1dp" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/vodafone_package_400gb"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="400GB / 30D"
                    android:textColor="@color/r2w_premium_primary"
                    app:chipBackgroundColor="#F8FAFF"
                    app:chipCornerRadius="16dp"
                    app:chipStrokeColor="#BFD4FF"
                    app:chipStrokeWidth="1dp" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/vodafone_package_500gb"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="500GB / 30D"
                    android:textColor="@color/r2w_premium_primary"
                    app:chipBackgroundColor="#F8FAFF"
                    app:chipCornerRadius="16dp"
                    app:chipStrokeColor="#BFD4FF"
                    app:chipStrokeWidth="1dp" />
                </com.google.android.material.chip.ChipGroup>
            </HorizontalScrollView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Customer Information"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:textColor="@color/r2w_premium_text"
                android:textStyle="bold"
                android:textAllCaps="false" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/vodafone_customer_name_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="Customer name"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                app:boxBackgroundColor="@color/r2w_premium_surface"
                app:boxCornerRadiusBottomEnd="18dp"
                app:boxCornerRadiusBottomStart="18dp"
                app:boxCornerRadiusTopEnd="18dp"
                app:boxCornerRadiusTopStart="18dp"
                app:boxStrokeColor="@color/r2w_premium_border"
                app:hintTextColor="@color/r2w_premium_muted">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/vodafone_customer_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPersonName" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/vodafone_customer_phone_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Phone number"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                app:boxBackgroundColor="@color/r2w_premium_surface"
                app:boxCornerRadiusBottomEnd="18dp"
                app:boxCornerRadiusBottomStart="18dp"
                app:boxCornerRadiusTopEnd="18dp"
                app:boxCornerRadiusTopStart="18dp"
                app:boxStrokeColor="@color/r2w_premium_border"
                app:hintTextColor="@color/r2w_premium_muted">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/vodafone_customer_phone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="phone" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/vodafone_customer_email_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Email optional"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                app:boxBackgroundColor="@color/r2w_premium_surface"
                app:boxCornerRadiusBottomEnd="18dp"
                app:boxCornerRadiusBottomStart="18dp"
                app:boxCornerRadiusTopEnd="18dp"
                app:boxCornerRadiusTopStart="18dp"
                app:boxStrokeColor="@color/r2w_premium_border"
                app:hintTextColor="@color/r2w_premium_muted">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/vodafone_customer_email"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textEmailAddress" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/vodafone_renew_button"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:background="@drawable/r2w_premium_primary_button"
                android:layout_marginTop="20dp"
                android:enabled="false"
                android:text="Continue Renewal"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:textAllCaps="false"
                app:backgroundTint="@null"
                app:cornerRadius="16dp" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
