<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/r2w_premium_bg">

    <include layout="@layout/toolbar_activity" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/mobile_esim_install_scroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <LinearLayout
            android:id="@+id/mobile_esim_install_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/r2w_screen_padding"
            android:paddingTop="20dp"
            android:paddingBottom="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/mobile_esim_install_heading"
                android:textAppearance="?attr/textAppearanceDisplaySmall"
                android:textColor="@color/r2w_premium_text" />

            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/mobile_esim_install_progress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:indeterminate="true"
                android:visibility="gone" />

            <TextView
                android:id="@+id/mobile_esim_install_error"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="@color/r2w_premium_danger"
                android:visibility="gone" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:cardBackgroundColor="@color/r2w_premium_surface"
                app:cardElevation="4dp"
                app:cardCornerRadius="@dimen/r2w_card_radius"
                app:strokeColor="@color/r2w_premium_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/r2w_card_padding">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/mobile_esim_install_compatibility_check"
                        android:textAppearance="?attr/textAppearanceTitleSmall"
                        android:textColor="@color/r2w_premium_text" />

                    <TextView
                        android:id="@+id/mobile_esim_install_compatibility_status"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="5dp"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        android:textColor="@color/r2w_premium_muted" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="@string/mobile_esim_install_device_check"
                        android:textAppearance="?attr/textAppearanceTitleSmall"
                        android:textColor="@color/r2w_premium_text" />

                    <TextView
                        android:id="@+id/mobile_esim_install_device_status"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="5dp"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        android:textColor="@color/r2w_premium_muted" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="@string/mobile_esim_install_download_profile"
                        android:textAppearance="?attr/textAppearanceTitleSmall"
                        android:textColor="@color/r2w_premium_text" />

                    <TextView
                        android:id="@+id/mobile_esim_install_download_status"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="5dp"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        android:textColor="@color/r2w_premium_muted" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/mobile_esim_install_smdp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:background="@drawable/r2w_premium_card_soft"
                android:padding="@dimen/r2w_card_padding"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="@color/r2w_premium_text" />

            <TextView
                android:id="@+id/mobile_esim_install_matching_id"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/r2w_premium_card_soft"
                android:padding="@dimen/r2w_card_padding"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="@color/r2w_premium_text" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/mobile_esim_install_start"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="24dp"
                android:background="@drawable/r2w_premium_primary_button"
                android:text="@string/mobile_esim_install_continue"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                app:backgroundTint="@null"
                app:cornerRadius="@dimen/r2w_button_radius" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/mobile_esim_install_retry"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="10dp"
                android:backgroundTint="@color/r2w_premium_surface"
                android:text="@string/mobile_esim_install_retry"
                android:textColor="@color/r2w_premium_primary"
                app:cornerRadius="@dimen/r2w_button_radius"
                app:strokeColor="@color/r2w_premium_border"
                app:strokeWidth="1dp"
                android:visibility="gone" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
