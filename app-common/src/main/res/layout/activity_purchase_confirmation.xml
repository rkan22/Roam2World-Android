<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/r2w_premium_bg">

    <include layout="@layout/toolbar_activity" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/purchase_confirmation_scroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <LinearLayout
            android:id="@+id/purchase_confirmation_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="@dimen/r2w_screen_padding">

            <LinearLayout
                android:id="@+id/confirm_purchase_hero_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="18dp"
                android:background="@drawable/r2w_confirm_purchase_hero_bg"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:paddingHorizontal="22dp"
                android:paddingTop="24dp"
                android:paddingBottom="22dp">

                <ImageView
                    android:id="@+id/confirm_purchase_hero_image"
                    android:layout_width="122dp"
                    android:layout_height="122dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_confirm_purchase_hero" />

                <TextView
                    android:id="@+id/confirm_purchase_hero_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:gravity="center"
                    android:text="Confirm Purchase"
                    android:textColor="@color/r2w_text_primary"
                    android:textSize="25sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/confirm_purchase_hero_subtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="7dp"
                    android:gravity="center"
                    android:text="Review the package and customer details before completing the order."
                    android:textColor="@color/r2w_text_secondary"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/confirm_purchase_hero_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="34dp"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/r2w_confirm_purchase_badge_bg"
                    android:gravity="center"
                    android:minWidth="128dp"
                    android:paddingHorizontal="16dp"
                    android:text="Ready to order"
                    android:textColor="#0F7A28"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>


            <FrameLayout
                android:layout_width="104dp"
                android:layout_height="104dp"
                android:background="@drawable/r2w_success_icon_bg">

                <ImageView
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_success_check" />
            </FrameLayout>

            <TextView
                android:id="@+id/purchase_confirmation_heading"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:gravity="center"
                android:text="Purchase Successful"
                android:textAppearance="?attr/textAppearanceDisplaySmall"
                android:textColor="@color/r2w_premium_text"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="Your eSIM has been purchased successfully and is ready to install."
                android:textAppearance="?attr/textAppearanceBodyLarge"
                android:textColor="@color/r2w_premium_muted" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                app:cardBackgroundColor="@color/r2w_premium_surface"
                app:cardCornerRadius="22dp"
                app:cardElevation="3dp"
                app:strokeColor="@color/r2w_premium_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/r2w_card_padding">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="eSIM Details"
                        android:textAppearance="?attr/textAppearanceTitleLarge"
                        android:textColor="#21A957"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/purchase_package_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:textAppearance="?attr/textAppearanceBodyLarge"
                        android:textColor="@color/r2w_premium_text" />

                    <TextView
                        android:id="@+id/purchase_iccid"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:textAppearance="?attr/textAppearanceBodyLarge"
                        android:textColor="@color/r2w_premium_text" />

                    <TextView
                        android:id="@+id/purchase_order_number"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:textAppearance="?attr/textAppearanceBodyLarge"
                        android:textColor="@color/r2w_premium_text" />

                    <TextView
                        android:id="@+id/purchase_order_status"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:textAppearance="?attr/textAppearanceBodyLarge"
                        android:textColor="@color/r2w_premium_text" />

                    <TextView
                        android:id="@+id/purchase_price"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:textAppearance="?attr/textAppearanceBodyLarge"
                        android:textColor="@color/r2w_premium_text" />

                    <TextView
                        android:id="@+id/purchase_balance_after"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:textAppearance="?attr/textAppearanceBodyLarge"
                        android:textColor="@color/r2w_premium_text" />

                    <TextView
                        android:id="@+id/purchase_esim_id"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="@color/r2w_premium_muted" />

                    <TextView
                        android:id="@+id/purchase_activation_code"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        android:textColor="@color/r2w_premium_muted" />

                    <TextView
                        android:id="@+id/purchase_smdp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        android:textColor="@color/r2w_premium_muted" />

                    <TextView
                        android:id="@+id/purchase_matching_id"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        android:textColor="@color/r2w_premium_muted" />

                    <TextView
                        android:id="@+id/purchase_qr_code"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        android:textColor="@color/r2w_premium_muted" />

                    <TextView
                        android:id="@+id/purchase_qr_url"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        android:textColor="@color/r2w_premium_muted" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/purchase_install_button"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="26dp"
                android:background="@drawable/r2w_premium_primary_button"
                android:text="Install eSIM Now"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                app:backgroundTint="@null"
                app:cornerRadius="16dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/purchase_open_openeuicc_button"
                                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:background="@drawable/r2w_purchase_secondary_button"
                android:layout_marginTop="12dp"
                android:text="Open OpenEUICC"
                app:cornerRadius="16dp"
                app:backgroundTint="@null"
                android:textColor="@color/r2w_premium_primary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/purchase_view_detail_button"
                                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:background="@drawable/r2w_purchase_secondary_button"
                android:layout_marginTop="12dp"
                android:text="View eSIM Detail"
                app:cornerRadius="16dp"
                app:backgroundTint="@null"
                android:textColor="@color/r2w_premium_primary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/purchase_dashboard_button"
                                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:background="@drawable/r2w_purchase_secondary_button"
                android:layout_marginTop="12dp"
                android:text="Back to Dashboard"
                app:cornerRadius="16dp"
                app:backgroundTint="@null"
                android:textColor="@color/r2w_premium_primary" />

            <TextView
                android:id="@+id/purchase_install_unavailable"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:text="Install code is not available yet. You can still open the eSIM detail later."
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="@color/r2w_premium_muted"
                android:visibility="gone" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
