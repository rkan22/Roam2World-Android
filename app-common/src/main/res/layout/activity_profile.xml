<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/r2w_premium_card_soft">

    <include layout="@layout/toolbar_activity" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/profile_scroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/r2w_screen_padding">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/r2w_premium_surface"
                app:cardCornerRadius="@dimen/r2w_card_radius"
                app:cardElevation="4dp"
                app:strokeColor="@color/r2w_premium_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/profile_avatar"
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:background="@drawable/r2w_premium_primary_button"
                        android:gravity="center"
                        android:text="R2W"
                        android:textColor="@android:color/white"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/profile_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Roam2World User"
                        android:textAppearance="?attr/textAppearanceHeadlineSmall"
                        android:textColor="@color/r2w_premium_text"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/profile_email"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="user@company.com"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="@color/r2w_premium_muted" />

                    <TextView
                        android:id="@+id/profile_role"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:background="@color/r2w_premium_bg"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="8dp"
                        android:text="Role: Reseller"
                        android:textColor="@color/r2w_premium_primary"
                        android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Company"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:textColor="@color/r2w_premium_text"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                app:cardBackgroundColor="@color/r2w_premium_surface"
                app:cardCornerRadius="@dimen/r2w_card_radius"
                app:cardElevation="4dp"
                app:strokeColor="@color/r2w_premium_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/r2w_card_padding">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Account Type"
                        android:textColor="@color/r2w_premium_muted" />

                    <TextView
                        android:id="@+id/profile_account_type"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="B2B Telecom Workspace"
                        android:textAppearance="?attr/textAppearanceTitleMedium"
                        android:textColor="@color/r2w_premium_text"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:text="Permissions"
                        android:textColor="@color/r2w_premium_muted" />

                    <TextView
                        android:id="@+id/profile_permissions"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="eSIM Store • Wallet • Reports • OpenEUICC"
                        android:textColor="@color/r2w_premium_text" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Account Actions"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:textColor="@color/r2w_premium_text"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/profile_settings"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="10dp"
                android:gravity="center_vertical"
                android:text="@string/r2w_settings"
                android:textColor="@color/r2w_premium_primary"
                app:cornerRadius="@dimen/r2w_button_radius" 
                android:backgroundTint="@color/r2w_premium_surface"
                app:strokeColor="@color/r2w_premium_border"
                app:strokeWidth="1dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/profile_logout"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="10dp"
                android:gravity="center_vertical"
                android:text="@string/logout"
                android:textColor="@color/r2w_premium_danger"
                app:cornerRadius="@dimen/r2w_button_radius" 
                android:backgroundTint="@color/r2w_premium_surface"
                app:strokeColor="@color/r2w_premium_border"
                app:strokeWidth="1dp"/>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
