<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/r2w_premium_bg">

    <include layout="@layout/toolbar_activity" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/allocate_balance_scroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <LinearLayout
            android:id="@+id/allocate_balance_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/r2w_screen_padding"
            android:paddingTop="22dp"
            android:paddingBottom="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/dashboard_brand"
                android:textAppearance="?attr/textAppearanceLabelLarge"
                android:textColor="@color/r2w_premium_primary" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/dealer_allocate_title"
                android:textAppearance="?attr/textAppearanceDisplaySmall"
                android:textColor="@color/r2w_premium_text" />

            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/allocate_balance_progress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:indeterminate="true"
                android:visibility="gone" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:cardBackgroundColor="@color/r2w_premium_surface"
                app:cardElevation="4dp"
                app:cardCornerRadius="@dimen/r2w_card_radius"
                app:strokeColor="@color/r2w_premium_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/r2w_card_padding">

                    <TextView
                        android:id="@+id/allocate_balance_dealer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textAppearance="?attr/textAppearanceTitleMedium"
                        android:textColor="@color/r2w_premium_text" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/allocate_balance_amount_layout"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:hint="@string/dealer_allocate_amount"
                        app:boxBackgroundColor="@color/r2w_premium_surface"
                        app:boxCornerRadiusBottomEnd="16dp"
                        app:boxCornerRadiusBottomStart="16dp"
                        app:boxCornerRadiusTopEnd="16dp"
                        app:boxCornerRadiusTopStart="16dp"
                        app:boxStrokeColor="@color/r2w_premium_border"
                        app:hintTextColor="@color/r2w_premium_muted">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/allocate_balance_amount"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="numberDecimal" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView
                        android:id="@+id/allocate_balance_error"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="@color/r2w_premium_danger"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/allocate_balance_success"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="@color/r2w_premium_primary"
                        android:visibility="gone" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/allocate_balance_submit"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="18dp"
                        android:background="@drawable/r2w_premium_primary_button"
                        android:text="@string/dealer_allocate_submit"
                        android:textColor="@android:color/white"
                        android:textStyle="bold"
                        app:backgroundTint="@null"
                        app:cornerRadius="@dimen/r2w_button_radius"
                        app:icon="@drawable/ic_wallet"
                        app:iconTint="@android:color/white" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
