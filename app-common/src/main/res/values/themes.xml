<resources>
    <!-- Base application theme. -->
    <style name="Theme.OpenEUICC" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/roam_primary</item>
        <item name="colorOnPrimary">@color/roam_on_primary</item>
        <item name="colorPrimaryContainer">@color/roam_primary_container</item>
        <item name="colorOnPrimaryContainer">@color/roam_on_primary_container</item>
        <item name="colorSecondary">@color/roam_secondary</item>
        <item name="colorOnSecondary">@color/roam_on_secondary</item>
        <item name="colorSecondaryContainer">@color/roam_secondary_container</item>
        <item name="colorOnSecondaryContainer">@color/roam_on_secondary_container</item>
        <item name="colorTertiary">@color/roam_tertiary</item>
        <item name="colorOnTertiary">@color/roam_on_tertiary</item>
        <item name="colorTertiaryContainer">@color/roam_tertiary_container</item>
        <item name="colorOnTertiaryContainer">@color/roam_on_tertiary_container</item>
        <item name="colorError">@color/roam_error</item>
        <item name="colorOnError">@color/roam_on_error</item>
        <item name="colorErrorContainer">@color/roam_error_container</item>
        <item name="colorOnErrorContainer">@color/roam_on_error_container</item>
        <item name="colorSurface">@color/roam_surface</item>
        <item name="colorOnSurface">@color/roam_on_surface</item>
        <item name="colorSurfaceVariant">@color/roam_surface_variant</item>
        <item name="colorOnSurfaceVariant">@color/roam_on_surface_variant</item>
        <item name="colorOutline">@color/roam_outline</item>
        <item name="colorOutlineVariant">@color/roam_outline_variant</item>
        <item name="android:windowLightStatusBar">?attr/isLightTheme</item>
        <item name="alertDialogTheme">@style/AlertDialogTheme</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightNavigationBar">?attr/isLightTheme</item>
        <item name="toolbarStyle">@style/ToolbarTheme</item>
        <item name="android:statusBarColor">?attr/colorSurfaceVariant</item>
        <item name="android:colorBackground">?attr/colorSurface</item>
        <item name="dialogCornerRadius">28dp</item>
            <item name="fontFamily">sans-serif</item>
        <item name="android:fontFamily">sans-serif</item>

        <item name="android:fontFamily">@font/r2w_google_sans</item>
        <item name="fontFamily">@font/r2w_google_sans</item>
            <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="ToolbarTheme" parent="Widget.Material3.Toolbar">
        <item name="android:background">?attr/colorSurface</item>
        <item name="titleTextColor">?attr/colorOnSurface</item>
        <item name="navigationIconTint">?attr/colorOnSurface</item>
            <item name="fontFamily">sans-serif</item>
        <item name="android:fontFamily">sans-serif</item>

        <item name="android:fontFamily">@font/r2w_google_sans</item>
        <item name="fontFamily">@font/r2w_google_sans</item>
    </style>

    <style name="AlertDialogTheme" parent="Theme.Material3.DayNight.Dialog.Alert">
        <item name="buttonBarNegativeButtonStyle">@style/NegativeButtonStyle</item>
        <item name="buttonBarPositiveButtonStyle">@style/PositiveButtonStyle</item>
        <item name="dialogCornerRadius">28dp</item>
            <item name="fontFamily">sans-serif</item>
        <item name="android:fontFamily">sans-serif</item>

        <item name="android:fontFamily">@font/r2w_google_sans</item>
        <item name="fontFamily">@font/r2w_google_sans</item>
    </style>

    <style name="NegativeButtonStyle" parent="Widget.Material3.Button.TextButton.Dialog">
        <item name="android:textColor">?attr/colorSecondary</item>
    </style>

    <style name="PositiveButtonStyle" parent="Widget.Material3.Button.TextButton.Dialog">
        <item name="android:textColor">?attr/colorSecondary</item>
    </style>

    <style name="Theme.AppCompat.Translucent" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:colorBackgroundCacheHint">@null</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowAnimationStyle">@android:style/Animation</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
            <item name="fontFamily">sans-serif</item>
        <item name="android:fontFamily">sans-serif</item>

        <item name="android:fontFamily">@font/r2w_google_sans</item>
        <item name="fontFamily">@font/r2w_google_sans</item>
    </style>

    <!-- Splash Screen Theme -->
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/roam_primary</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_logo</item>
        <item name="postSplashScreenTheme">@style/Theme.OpenEUICC</item>
    </style>


    <style name="Theme.Roam2World.Dashboard" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="windowActionBar">false</item>
        <item name="android:statusBarColor">#F4F6FA</item>
        <item name="android:navigationBarColor">#FFFFFF</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:fontFamily">sans</item>
    </style>


    <style name="Theme.Roam2World.Splash" parent="android:style/Theme.Material.Light.NoActionBar">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowBackground">#07142F</item>
        <item name="android:navigationBarColor">#07142F</item>
        <item name="android:statusBarColor">#07142F</item>
    </style>


    <style name="Theme.Roam2World.Detail" parent="android:style/Theme.Material.Light.NoActionBar">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowBackground">#F5F8FC</item>
        <item name="android:statusBarColor">#F5F8FC</item>
        <item name="android:navigationBarColor">#000000</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>


    <style name="Theme.Roam2World.CustomerInfo" parent="android:style/Theme.Material.Light.NoActionBar">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowBackground">#F4F8FD</item>
        <item name="android:statusBarColor">#F4F8FD</item>
        <item name="android:navigationBarColor">#000000</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>


    <style name="Theme.Roam2World.PurchaseReview" parent="android:style/Theme.Material.Light.NoActionBar">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowBackground">#F4F8FD</item>
        <item name="android:statusBarColor">#F4F8FD</item>
        <item name="android:navigationBarColor">#000000</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>


    <style name="Theme.Roam2World.MobileEsims" parent="android:style/Theme.Material.Light.NoActionBar">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:fontFamily">sans</item>
        <item name="android:colorAccent">#1263F1</item>
        <item name="android:navigationBarColor">#FFFFFF</item>
        <item name="android:statusBarColor">#F4F6FA</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

</resources>
