<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F4F8FF"
    android:padding="18dp">

    
    <TextView
        android:id="@+id/adminSupportTicketsTitleText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Support Tickets"
        android:textColor="#07133D"
        android:textSize="26sp"
        android:textStyle="bold"
        android:paddingBottom="4dp" />

    <TextView
        android:id="@+id/adminSupportTicketsSubtitleText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Support requests"
        android:textColor="#53627C"
        android:textSize="14sp"
        android:paddingBottom="12dp" />

<Button
        android:id="@+id/adminSupportTicketsRefreshButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Refresh"
        android:textColor="#FFFFFF"
        android:background="@drawable/admin_menu_button"
        android:layout_marginBottom="12dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:id="@+id/adminSupportTicketsListContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

    </ScrollView>

</LinearLayout>
