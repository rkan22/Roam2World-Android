<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F6F8FC">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="82dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingLeft="16dp"
            android:paddingTop="16dp"
            android:paddingRight="16dp"
            android:paddingBottom="24dp">

            <!-- HERO -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="128dp"
                android:background="@drawable/admin_hero_background"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/admin_icon_shield"
                        android:contentDescription="@null" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="10dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Roam2World"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Admin Console"
                            android:textColor="#C9D7FF"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/notificationPreviewText"
                        android:layout_width="wrap_content"
                        android:layout_height="30dp"
                        android:background="@drawable/admin_material_alert_pill"
                        android:gravity="center"
                        android:paddingLeft="12dp"
                        android:paddingRight="12dp"
                        android:text="Alerts"
                        android:textColor="#FFFFFF"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="22dp"
                    android:text="Welcome back, Admin"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Overview &amp; operations summary"
                    android:textColor="#C9D7FF"
                    android:textSize="11sp" />
            </LinearLayout>

            <!-- LIVE KPI GRID -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:columnCount="2">

                <LinearLayout style="@style/AdminLiveKpiCard">
                    <ImageView style="@style/AdminLiveIcon" android:src="@drawable/admin_icon_money" />
                    <TextView
                        android:id="@+id/walletSummaryText"
                        style="@style/AdminLiveKpiText"
                        android:text="Revenue\nLoading..." />
                </LinearLayout>

                <LinearLayout style="@style/AdminLiveKpiCard">
                    <ImageView style="@style/AdminLiveIcon" android:src="@drawable/admin_icon_orders" />
                    <TextView
                        android:id="@+id/orderMetricText"
                        style="@style/AdminLiveKpiText"
                        android:text="Orders\nLoading..." />
                </LinearLayout>

                <LinearLayout style="@style/AdminLiveKpiCard">
                    <ImageView style="@style/AdminLiveIcon" android:src="@drawable/admin_icon_partners" />
                    <TextView
                        android:id="@+id/resellerCountText"
                        style="@style/AdminLiveKpiText"
                        android:text="Resellers\nLoading..." />
                </LinearLayout>

                <LinearLayout style="@style/AdminLiveKpiCard">
                    <ImageView style="@style/AdminLiveIcon" android:src="@drawable/admin_icon_health" />
                    <TextView
                        android:id="@+id/dealerCountText"
                        style="@style/AdminLiveKpiText"
                        android:text="Dealers\nLoading..." />
                </LinearLayout>
            </GridLayout>

            <!-- LIVE SALES -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/admin_material_card"
                android:orientation="vertical"
                android:padding="14dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Sales Performance"
                        android:textColor="#101828"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="This Week"
                        android:textColor="#1263F1"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="126dp"
                    android:layout_marginTop="10dp"
                    android:src="@drawable/admin_chart_sales"
                    android:scaleType="fitXY"
                    android:contentDescription="@null" />

                <TextView
                    android:id="@+id/salesOverviewText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Sales Overview\nLoading..."
                    android:textColor="#344054"
                    android:textSize="12sp"
                    android:lineSpacingExtra="2dp" />
            </LinearLayout>

            <!-- LIVE STATUS -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:columnCount="2">

                <LinearLayout style="@style/AdminLiveStatusCard">
                    <ImageView style="@style/AdminLiveSmallIcon" android:src="@drawable/admin_icon_money" />
                    <TextView
                        android:id="@+id/pendingRequestsText"
                        style="@style/AdminLiveStatusText"
                        android:text="Pending Wallet\nLoading..." />
                </LinearLayout>

                <LinearLayout style="@style/AdminLiveStatusCard">
                    <ImageView style="@style/AdminLiveSmallIcon" android:src="@drawable/admin_icon_health" />
                    <TextView
                        android:id="@+id/systemAlertsText"
                        style="@style/AdminLiveStatusText"
                        android:text="System Alerts\nLoading..." />
                </LinearLayout>
            </GridLayout>

            <!-- QUICK ACTIONS -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Quick Actions"
                    android:textColor="#101828"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="View all"
                    android:textColor="#1263F1"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:columnCount="4">

                <Button
                    android:id="@+id/openOrdersButton"
                    style="@style/AdminLiveQuickButton"
                    android:drawableTop="@drawable/admin_icon_orders"
                    android:text="Orders" />

                <Button
                    android:id="@+id/openResellersButton"
                    style="@style/AdminLiveQuickButton"
                    android:drawableTop="@drawable/admin_icon_partners"
                    android:text="Partners" />

                <Button
                    android:id="@+id/openApprovalsButton"
                    style="@style/AdminLiveQuickButton"
                    android:drawableTop="@drawable/admin_icon_money"
                    android:text="Wallet" />

                <Button
                    android:id="@+id/openReportsButton"
                    style="@style/AdminLiveQuickButton"
                    android:drawableTop="@drawable/admin_icon_reports"
                    android:text="Reports" />
            </GridLayout>

            <!-- RECENT / PREVIEW CARDS -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/admin_material_card"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Recent Activity"
                    android:textColor="#101828"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/pendingWalletPreviewText"
                    style="@style/AdminLivePreviewText"
                    android:text="Pending Wallet Requests\nLoading..." />

                <TextView
                    android:id="@+id/resellerPreviewText"
                    style="@style/AdminLivePreviewText"
                    android:text="Reseller Management\nLoading..." />

                <TextView
                    android:id="@+id/pricingPreviewText"
                    style="@style/AdminLivePreviewText"
                    android:text="Pricing Management\nLoading..." />
            </LinearLayout>

            <!-- Hidden action ids required by MobileAdminActivity; visual tools live in More screen -->
            <Button android:id="@+id/openDealersButton" style="@style/AdminHiddenAction" />
            <Button android:id="@+id/openPricingButton" style="@style/AdminHiddenAction" />
            <Button android:id="@+id/openSystemHealthButton" style="@style/AdminHiddenAction" />
            <Button android:id="@+id/openAuditLogsButton" style="@style/AdminHiddenAction" />
            <Button android:id="@+id/openSupportTicketsButton" style="@style/AdminHiddenAction" />
            <Button android:id="@+id/openNotificationsButton" style="@style/AdminHiddenAction" />
            <Button android:id="@+id/refreshButton" style="@style/AdminHiddenAction" />

        </LinearLayout>
    </ScrollView>

    <!-- BOTTOM NAV -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_gravity="bottom"
        android:background="#FFFFFF"
        android:elevation="18dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingLeft="8dp"
        android:paddingRight="8dp">

        <TextView android:id="@+id/bottomDashboardNav" style="@style/AdminPngBottomSelected" android:drawableTop="@drawable/admin_icon_briefcase" android:text="Dashboard" />
        <TextView android:id="@+id/bottomResellersNav" style="@style/AdminPngBottom" android:drawableTop="@drawable/admin_icon_partners" android:text="Partners" />
        <TextView android:id="@+id/bottomWalletNav" style="@style/AdminPngBottom" android:drawableTop="@drawable/admin_icon_orders" android:text="Orders" />
        <TextView android:id="@+id/bottomPricingNav" style="@style/AdminPngBottom" android:drawableTop="@drawable/admin_icon_tag" android:text="Pricing" />
        <TextView android:id="@+id/bottomMoreNav" style="@style/AdminPngBottom" android:drawableTop="@drawable/admin_icon_settings" android:text="More" />

    </LinearLayout>

</FrameLayout>
