<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="AdminLiveKpiCard">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">78dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:layout_margin">5dp</item>
        <item name="android:background">@drawable/admin_material_card</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:padding">10dp</item>
    </style>

    <style name="AdminLiveIcon">
        <item name="android:layout_width">28dp</item>
        <item name="android:layout_height">28dp</item>
        <item name="android:layout_marginRight">10dp</item>
        <item name="android:scaleType">fitCenter</item>
    </style>

    <style name="AdminLiveKpiText">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:textColor">#101828</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:maxLines">3</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:lineSpacingExtra">1dp</item>
    </style>

    <style name="AdminLiveStatusCard">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">76dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:layout_margin">5dp</item>
        <item name="android:background">@drawable/admin_material_card</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:padding">10dp</item>
    </style>

    <style name="AdminLiveSmallIcon">
        <item name="android:layout_width">30dp</item>
        <item name="android:layout_height">30dp</item>
        <item name="android:layout_marginRight">8dp</item>
        <item name="android:scaleType">fitCenter</item>
    </style>

    <style name="AdminLiveStatusText">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:textColor">#101828</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:maxLines">3</item>
        <item name="android:includeFontPadding">false</item>
    </style>

    <style name="AdminLiveQuickButton">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">76dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:layout_margin">5dp</item>
        <item name="android:background">@drawable/admin_material_card</item>
        <item name="android:backgroundTint">@null</item>
        <item name="android:textColor">#101828</item>
        <item name="android:textSize">10sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:drawablePadding">4dp</item>
        <item name="android:padding">6dp</item>
        <item name="android:elevation">0dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:minWidth">0dp</item>
    </style>

    <style name="AdminLiveToolButton">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">70dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:layout_margin">5dp</item>
        <item name="android:background">@drawable/admin_material_card_soft</item>
        <item name="android:backgroundTint">@null</item>
        <item name="android:textColor">#1263F1</item>
        <item name="android:textSize">10sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:drawablePadding">4dp</item>
        <item name="android:padding">6dp</item>
        <item name="android:elevation">0dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:minWidth">0dp</item>
    </style>

    <style name="AdminLivePreviewText">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">9dp</item>
        <item name="android:paddingTop">8dp</item>
        <item name="android:textColor">#344054</item>
        <item name="android:textSize">11sp</item>
        <item name="android:lineSpacingExtra">1dp</item>
        <item name="android:includeFontPadding">false</item>
    </style>

    <style name="AdminPngBottom">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">56dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">#667085</item>
        <item name="android:textSize">9sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:drawablePadding">2dp</item>
        <item name="android:includeFontPadding">false</item>
    </style>

    <style name="AdminPngBottomSelected">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">56dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:gravity">center</item>
        <item name="android:background">@drawable/admin_material_bottom_selected</item>
        <item name="android:textColor">#1263F1</item>
        <item name="android:textSize">9sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:drawablePadding">2dp</item>
        <item name="android:includeFontPadding">false</item>
    </style>

    <style name="AdminHiddenAction">
        <item name="android:layout_width">1dp</item>
        <item name="android:layout_height">1dp</item>
        <item name="android:visibility">gone</item>
        <item name="android:background">@drawable/admin_transparent_click</item>
        <item name="android:backgroundTint">@null</item>
        <item name="android:text"></item>
        <item name="android:minHeight">0dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:padding">0dp</item>
    </style>
</resources>
